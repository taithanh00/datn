@model IEnumerable<datn.Models.StudyReport>
@{
    Layout = "_DashboardLayout";
    var children = ViewBag.Children as List<datn.Models.Student> ?? new List<datn.Models.Student>();
    var selectedStudentId = ViewBag.SelectedStudentId as int?;
    var selectedYear = ViewBag.SelectedYear as int? ?? DateTime.Now.Year;
    var selectedStudent = children.FirstOrDefault(c => c.Id == selectedStudentId);
}

<div class="page-header">
    <div>
        <h1 class="page-title">Kết quả học tập</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Xem đánh giá hàng tháng của giáo viên dành cho bé</p>
    </div>
    <div class="d-flex gap-2">
        @if (children.Count > 1)
        {
            <select class="form-select" style="width: 200px;" onchange="location.href='?year=@selectedYear&studentId=' + this.value">
                @foreach (var child in children)
                {
                    var isSelChild = child.Id == selectedStudentId;
                    <option value="@child.Id" selected="@isSelChild">Bé: @child.FirstName @child.LastName</option>
                }
            </select>
        }
        <select class="form-select" style="width: 120px;" onchange="location.href='?studentId=@selectedStudentId&year=' + this.value">
            @for (int y = 2025; y <= 2027; y++)
            {
                var isSelYear = y == selectedYear;
                <option value="@y" selected="@isSelYear">Năm @y</option>
            }
        </select>
    </div>
</div>

@if (selectedStudent != null)
{
    <div class="card" style="background: linear-gradient(135deg, var(--primary) 0%, #4338CA 100%); color: white; margin-bottom: 24px; border: none;">
        <div class="d-flex align-center gap-3">
            <img src="@(selectedStudent.AvatarPath ?? "/images/lion_orange.png")" style="width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 3px solid rgba(255,255,255,0.3);" onerror="this.src='/images/lion_orange.png'">
            <div>
                <h2 style="margin: 0 0 4px 0; color: white;">@selectedStudent.FirstName @selectedStudent.LastName</h2>
                <div style="opacity: 0.8; font-size: 0.9rem;">
                    <i class="fa-solid fa-school me-1"></i> Lớp: @(selectedStudent.Class?.Name ?? "N/A") <span style="margin: 0 8px;">|</span> Niên khóa: @selectedYear
                </div>
            </div>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="card" style="padding: 60px 20px; text-align: center;">
        <div class="empty-state">
            <i class="fa-solid fa-folder-open"></i>
            <h3 style="margin-bottom: 8px;">Chưa có đánh giá nào</h3>
            <p>Giáo viên chưa cập nhật đánh giá cho năm @selectedYear</p>
        </div>
    </div>
}
else
{
    <div class="card-grid" style="grid-template-columns: 1fr 1fr;">
        @foreach (var report in Model)
        {
            var rankingClass = "badge-warning";
            if (report.Ranking?.Name?.Contains("Xuất sắc") == true || report.Ranking?.Name?.Contains("Tốt") == true) rankingClass = "badge-success";
            if (report.Ranking?.Name?.Contains("Cần cố gắng") == true || report.Ranking?.Name?.Contains("Yếu") == true) rankingClass = "badge-danger";

            <div class="card d-flex flex-column">
                <div class="d-flex align-center gap-3 mb-3 pb-3" style="border-bottom: 1px dashed var(--border);">
                    <div style="width: 56px; height: 56px; border-radius: 12px; background: var(--primary-soft); color: var(--primary); display: flex; flex-direction: column; align-items: center; justify-content: center;">
                        <span style="font-size: 0.6rem; text-transform: uppercase; font-weight: 700;">Tháng</span>
                        <span style="font-size: 1.25rem; font-weight: 800;">@report.Date.Month</span>
                    </div>
                    <div style="flex: 1;">
                        <div class="d-flex justify-between align-start mb-1">
                            <h4 style="margin: 0; font-size: 1.1rem;">Đánh giá tháng @report.Date.Month</h4>
                            @if (report.Ranking != null)
                            {
                                <span class="badge @rankingClass" style="font-size: 0.75rem;">@report.Ranking.Name</span>
                            }
                        </div>
                        <div class="text-muted" style="font-size: 0.85rem;"><i class="fa-solid fa-user-edit me-1"></i> GV: @(report.Teacher?.FullName ?? "N/A")</div>
                    </div>
                </div>
                
                <div style="background: var(--bg-body); padding: 16px; border-radius: 8px; border-left: 3px solid var(--primary); flex: 1;">
                    <p style="margin: 0; font-style: italic; color: var(--text-secondary); font-size: 0.95rem; line-height: 1.5;">
                        "@(string.IsNullOrEmpty(report.Comment) ? "Chưa có nhận xét chi tiết." : report.Comment)"
                    </p>
                </div>
            </div>
        }
    </div>
}

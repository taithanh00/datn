@model IEnumerable<datn.Models.Attendance>
@{
    Layout = "_DashboardLayout";
    var children = ViewBag.Children as List<datn.Models.Student> ?? new List<datn.Models.Student>();
    var selectedStudentId = ViewBag.SelectedStudentId as int?;
    var selectedMonth = ViewBag.SelectedMonth as int? ?? DateTime.Now.Month;
    var selectedYear = ViewBag.SelectedYear as int? ?? DateTime.Now.Year;
    var selectedStudent = children.FirstOrDefault(c => c.Id == selectedStudentId);

    var totalPresent = Model.Count(a => a.Status == "Present");
    var totalExcused = Model.Count(a => a.Status == "Excused");
    var totalAbsent = Model.Count(a => a.Status == "Absent");
}

<div class="page-header">
    <div>
        <h1 class="page-title">Báo cáo Điểm danh</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Theo dõi chuyên cần hàng tháng của bé</p>
    </div>
    <div class="d-flex gap-2">
        @if (children.Count > 1)
        {
            <select class="form-select" style="width: 200px;" onchange="updateFilter('studentId', this.value)">
                @foreach (var child in children)
                {
                    var isSel = child.Id == selectedStudentId;
                    <option value="@child.Id" selected="@isSel">Bé: @child.FirstName @child.LastName</option>
                }
            </select>
        }
        <select class="form-select" style="width: 130px;" onchange="updateFilter('month', this.value)">
            @for (int m = 1; m <= 12; m++)
            {
                var isSelM = m == selectedMonth;
                <option value="@m" selected="@isSelM">Tháng @m</option>
            }
        </select>
        <select class="form-select" style="width: 110px;" onchange="updateFilter('year', this.value)">
            @for (int y = 2025; y <= 2027; y++)
            {
                var isSelY = y == selectedYear;
                <option value="@y" selected="@isSelY">Năm @y</option>
            }
        </select>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom: 24px;">
    <div class="card stat-card" style="border-top: 4px solid var(--success);">
        <div class="d-flex align-center gap-2">
            <div class="avatar" style="background: rgba(52,211,153,0.15); color: var(--success);"><i class="fa-solid fa-check-to-slot"></i></div>
            <div>
                <div class="stat-value" style="color: var(--success);">@totalPresent</div>
                <div class="stat-title">Ngày đi học</div>
            </div>
        </div>
    </div>
    <div class="card stat-card" style="border-top: 4px solid var(--warning);">
        <div class="d-flex align-center gap-2">
            <div class="avatar" style="background: rgba(251,191,36,0.15); color: var(--warning);"><i class="fa-solid fa-info-circle"></i></div>
            <div>
                <div class="stat-value" style="color: var(--warning);">@totalExcused</div>
                <div class="stat-title">Nghỉ có phép</div>
            </div>
        </div>
    </div>
    <div class="card stat-card" style="border-top: 4px solid var(--danger);">
        <div class="d-flex align-center gap-2">
            <div class="avatar" style="background: rgba(248,113,113,0.15); color: var(--danger);"><i class="fa-solid fa-xmark"></i></div>
            <div>
                <div class="stat-value" style="color: var(--danger);">@totalAbsent</div>
                <div class="stat-title">Vắng mặt</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header" style="margin-bottom: 16px;">
        <h3 style="margin: 0;">Chi tiết điểm danh tháng @selectedMonth/@selectedYear</h3>
    </div>
    
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Ngày</th>
                    <th>Thứ</th>
                    <th>Trạng thái</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <div class="empty-state">
                                <i class="fa-solid fa-calendar-xmark"></i>
                                <p>Không có dữ liệu điểm danh trong tháng này.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        var statusClass = item.Status switch
                        {
                            "Present" => "badge-success",
                            "Excused" => "badge-warning",
                            "Absent" => "badge-danger",
                            _ => "badge-info"
                        };
                        var statusText = item.Status switch
                        {
                            "Present" => "Có mặt",
                            "Excused" => "Có phép",
                            "Absent" => "Vắng mặt",
                            _ => item.Status
                        };
                        var statusIcon = item.Status switch
                        {
                            "Present" => "fa-check",
                            "Excused" => "fa-info",
                            "Absent" => "fa-xmark",
                            _ => "fa-circle-question"
                        };
                        
                        <tr>
                            <td style="font-weight: 600;">@item.Date.ToString("dd/MM/yyyy")</td>
                            <td>@item.Date.ToString("dddd", new System.Globalization.CultureInfo("vi-VN"))</td>
                            <td>
                                <span class="badge @statusClass"><i class="fa-solid @statusIcon"></i> @statusText</span>
                            </td>
                            <td class="text-muted" style="font-size: 0.9rem;">
                                @if (item.Status == "Present") {
                                    <span style="color: var(--success);"><i class="fa-solid fa-check me-1"></i> Bé đi học ngoan</span>
                                } else {
                                    <span>--</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/parent-attendance.js" asp-append-version="true"></script>
}

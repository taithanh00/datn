@model IEnumerable<datn.Models.TeachingPlan>
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var children = ViewBag.Children as List<datn.Models.Student> ?? new List<datn.Models.Student>();
    var selectedStudentId = ViewBag.SelectedStudentId;
}

<div class="dashboard-card">
    <div class="card-header">
        <h2 style="margin: 0;">Kế hoạch học tập của con</h2>
    </div>
    <div class="card-body">
        <p>Theo dõi các chủ đề và nội dung học tập mà con đang thực hiện tại lớp.</p>
        
        <div style="display: flex; gap: 10px; align-items: center; margin-top: 15px;">
            <label>Chọn con:</label>
            <select class="form-select" style="width: 200px;" onchange="location.href='?studentId=' + this.value">
                @foreach (var child in children)
                {
                    <option value="@child.Id" selected="@(child.Id == (int)selectedStudentId)">@child.FirstName @child.LastName</option>
                }
            </select>
        </div>
    </div>
</div>

<div class="dashboard-card" style="margin-top: 20px;">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div style="text-align: center; padding: 40px; color: #666;">
                <p>Hiện chưa có kế hoạch học tập nào được cập nhật cho lớp của con.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="management-table">
                    <thead>
                        <tr>
                            <th>Chủ đề/Chương trình</th>
                            <th>Môn học</th>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th>Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Curriculum.Title</strong>
                                    <div class="note-muted" style="font-size: 0.85em;">@item.Curriculum.Description</div>
                                </td>
                                <td>@(item.Curriculum.Subject?.Name ?? "Chung")</td>
                                <td>@item.StartDate.ToString("dd/MM/yyyy") @(item.EndDate.HasValue ? " - " + item.EndDate.Value.ToString("dd/MM/yyyy") : "")</td>
                                <td>
                                    <span class="status-badge @item.Status?.ToLower()">
                                        @switch(item.Status) {
                                            case "Planned": <span>Đã lên lịch</span> break;
                                            case "InProgress": <span>Đang học</span> break;
                                            case "Completed": <span>Đã hoàn thành</span> break;
                                            default: <span>@item.Status</span> break;
                                        }
                                    </span>
                                </td>
                                <td>
                                    <button class="btn-table" onclick="showDetail('@item.Curriculum.Title', `@item.Curriculum.Content`)">Xem nội dung</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Modal xem chi tiết -->
<div id="parentDetailModal" class="dashboard-card" style="display:none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000; width: 85%; max-width: 700px; box-shadow: 0 0 20px rgba(0,0,0,0.5);">
    <div class="card-header section-header">
        <h3 id="pModalTitle">Chi tiết bài học</h3>
        <button type="button" class="btn-table" onclick="closePModal()">Đóng</button>
    </div>
    <div class="card-body" style="max-height: 450px; overflow-y: auto;">
        <div id="pModalContent" style="white-space: pre-wrap; background: #f9f9f9; padding: 15px; border-radius: 4px; border: 1px solid #eee;"></div>
    </div>
</div>
<div id="pModalOverlay" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999;" onclick="closePModal()"></div>

@section Scripts {
    <script>
        function showDetail(title, content) {
            document.getElementById('pModalTitle').textContent = title;
            document.getElementById('pModalContent').textContent = content || 'Chưa có nội dung chi tiết.';
            document.getElementById('parentDetailModal').style.display = 'block';
            document.getElementById('pModalOverlay').style.display = 'block';
        }

        function closePModal() {
            document.getElementById('parentDetailModal').style.display = 'none';
            document.getElementById('pModalOverlay').style.display = 'none';
        }
    </script>
}

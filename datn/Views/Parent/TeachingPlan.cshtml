@model IEnumerable<datn.Models.TeachingPlan>
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var children = ViewBag.Children as List<datn.Models.Student> ?? new List<datn.Models.Student>();
    var selectedStudentId = ViewBag.SelectedStudentId;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Kế hoạch học tập của con</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Theo dõi các chủ đề và nội dung học tập mà con đang thực hiện tại lớp.</p>
    </div>
    <div class="d-flex gap-2">
        @if (children.Count > 1)
        {
            <div class="d-flex align-center gap-2">
                <label class="form-label" style="margin-bottom: 0;">Chọn con:</label>
                <select class="form-select" style="width: 200px;" onchange="location.href='?studentId=' + this.value">
                    @foreach (var child in children)
                    {
                        <option value="@child.Id" selected="@(child.Id == (int)selectedStudentId)">@child.FirstName @child.LastName</option>
                    }
                </select>
            </div>
        }
    </div>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div class="empty-state py-5">
            <i class="fa-solid fa-book-open"></i>
            <h3 style="margin-bottom: 8px;">Chưa có kế hoạch</h3>
            <p>Hiện chưa có kế hoạch học tập nào được cập nhật cho lớp của con.</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table id="teachingPlansTable">
                <thead>
                    <tr>
                        <th>Chủ đề/Chương trình</th>
                        <th>Môn học</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                        <th style="text-align: right;">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var statusClass = item.Status?.ToLower();
                        var statusText = item.Status switch {
                            "Planned" => "Đã lên lịch",
                            "InProgress" => "Đang học",
                            "Completed" => "Đã hoàn thành",
                            _ => item.Status
                        };

                        <tr>
                            <td>
                                <strong>@item.Curriculum.Title</strong>
                                <div class="text-muted" style="font-size: 0.85rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@item.Curriculum.Description</div>
                            </td>
                            <td><div class="badge badge-info">@(item.Curriculum.Subject?.Name ?? "Chung")</div></td>
                            <td>@item.StartDate.ToString("dd/MM/yyyy") <i class="fa-solid fa-arrow-right mx-1 text-muted"></i> @(item.EndDate.HasValue ? item.EndDate.Value.ToString("dd/MM/yyyy") : "...")</td>
                            <td>
                                <span class="badge @(statusClass == "planned" ? "badge-info" : statusClass == "inprogress" ? "badge-warning" : "badge-success")">
                                    @statusText
                                </span>
                            </td>
                            <td style="text-align: right;">
                                <button class="btn btn-outline" style="padding: 6px 12px; font-size: 0.85rem;" onclick="showDetail('@item.Curriculum.Title', `@(item.Curriculum.Content ?? "")`)">
                                    <i class="fa-solid fa-eye"></i> Xem nội dung
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal xem chi tiết -->
<div class="modal-overlay" id="pModalOverlay">
    <div class="modal-card" style="width: 700px; max-width: 95vw;">
        <div class="modal-header">
            <div class="modal-title" id="pModalTitle">Chi tiết bài học</div>
            <button class="modal-close" onclick="closePModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="max-height: 60vh; overflow-y: auto;">
            <div id="pModalContent" style="white-space: pre-wrap; background: var(--bg-body); padding: 16px; border-radius: var(--radius-sm); border: 1px solid var(--border); font-size: 0.95rem; line-height: 1.6; color: var(--text-main);"></div>
        </div>
        <div class="d-flex justify-end mt-3" style="padding-top: 16px; border-top: 1px solid var(--border);">
            <button type="button" class="btn btn-outline" onclick="closePModal()">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/parent-teaching-plans.js" asp-append-version="true"></script>
}

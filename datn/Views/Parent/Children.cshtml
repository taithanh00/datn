@model IEnumerable<datn.Models.Student>
@{
    Layout = "_DashboardLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/parent.css" asp-append-version="true" />
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Hồ sơ của bé</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">Hồ sơ của bé</li>
    </ol>

    <div class="row g-4">
        @foreach (var student in Model)
        {
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 16px;">
                    <div class="card-body p-0">
                        <div class="row g-0">
                            <div class="col-md-4 text-center p-4 bg-light d-flex flex-column align-items-center justify-content-center">
                                <img src="@(student.AvatarPath ?? "/images/lion_orange.png")" 
                                     class="rounded-circle shadow-sm border border-4 border-white mb-3" 
                                     style="width: 120px; height: 120px; object-fit: cover;"
                                     onerror="this.src='/images/lion_orange.png'">
                                <h4 class="mb-1 fw-bold">@student.FirstName @student.LastName</h4>
                                <span class="badge bg-primary rounded-pill px-3">@student.Class?.Name</span>
                            </div>
                            <div class="col-md-8 p-4">
                                <h5 class="border-bottom pb-2 mb-3 fw-bold text-primary">Thông tin chi tiết</h5>
                                <div class="row g-3">
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Giới tính</label>
                                        <span class="fw-bold">@(student.Gender == true ? "Nam" : "Nữ")</span>
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Ngày sinh</label>
                                        <span class="fw-bold">@(student.DateOfBirth?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Ngày nhập học</label>
                                        <span class="fw-bold">@(student.EnrollDate?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Mã học sinh</label>
                                        <span class="fw-bold">#@student.Id</span>
                                    </div>
                                    <div class="col-12">
                                        <label class="small text-muted d-block">Địa chỉ</label>
                                        <span class="fw-bold text-truncate d-block">@student.Address</span>
                                    </div>
                                </div>
                                <div class="mt-4 pt-3 border-top d-flex gap-2">
                                    <a href="/Parent/StudyReports?studentId=@student.Id" class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1">
                                        <i class="fas fa-chart-line me-1"></i> Học tập
                                    </a>
                                    <a href="/Parent/AttendanceReport?studentId=@student.Id" class="btn btn-outline-info btn-sm rounded-pill flex-grow-1">
                                        <i class="fas fa-calendar-check me-1"></i> Chuyên cần
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

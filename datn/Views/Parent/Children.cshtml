@model IEnumerable<datn.Models.Student>
@{
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Hồ sơ của bé</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Thông tin chi tiết các bé nhà bạn</p>
    </div>
</div>

<div class="card-grid" style="grid-template-columns: 1fr 1fr;">
    @foreach (var student in Model)
    {
        <div class="card" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
            <div style="background: linear-gradient(135deg, var(--primary) 0%, #4338CA 100%); padding: 32px 24px; text-align: center; color: white;">
                <img src="@(student.AvatarPath ?? "/images/lion_orange.png")" 
                     style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 4px solid rgba(255,255,255,0.2); box-shadow: 0 8px 16px rgba(0,0,0,0.1); margin-bottom: 16px; background: white;"
                     onerror="this.src='/images/lion_orange.png'">
                <h2 style="margin: 0 0 8px 0; font-size: 1.5rem; font-weight: 700; color: white;">@student.FirstName @student.LastName</h2>
                <div class="badge" style="background: rgba(255,255,255,0.2); color: white; border: none; font-size: 0.85rem;"><i class="fa-solid fa-school"></i> Lớp @student.Class?.Name</div>
            </div>
            
            <div style="padding: 24px;">
                <h4 style="font-size: 1rem; font-weight: 700; margin-bottom: 16px; color: var(--text-main); border-bottom: 1px solid var(--border); padding-bottom: 8px;">Thông tin cá nhân</h4>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                    <div>
                        <div class="text-muted" style="font-size: 0.8rem; margin-bottom: 4px;">Giới tính</div>
                        <div style="font-weight: 600;">@(student.Gender == true ? "Nam" : "Nữ")</div>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size: 0.8rem; margin-bottom: 4px;">Ngày sinh</div>
                        <div style="font-weight: 600;">@(student.DateOfBirth?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size: 0.8rem; margin-bottom: 4px;">Ngày nhập học</div>
                        <div style="font-weight: 600;">@(student.EnrollDate?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                    </div>
                    <div>
                        <div class="text-muted" style="font-size: 0.8rem; margin-bottom: 4px;">Mã học sinh</div>
                        <div style="font-weight: 600; color: var(--primary);">#@student.Id</div>
                    </div>
                    <div style="grid-column: 1 / -1;">
                        <div class="text-muted" style="font-size: 0.8rem; margin-bottom: 4px;">Địa chỉ</div>
                        <div style="font-weight: 600;">@student.Address</div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; border-top: 1px solid var(--border); padding-top: 20px;">
                    <a href="/Parent/StudyReports?studentId=@student.Id" class="btn btn-primary" style="justify-content: center;">
                        <i class="fa-solid fa-chart-line"></i> Học tập
                    </a>
                    <a href="/Parent/AttendanceReport?studentId=@student.Id" class="btn btn-outline" style="justify-content: center;">
                        <i class="fa-solid fa-calendar-check"></i> Chuyên cần
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var role = ViewBag.Role as string ?? "";
}

<div class="dashboard-card">
    <div class="card-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h2 style="margin: 0;">Dashboard - Chào mừng trở lại! 👋</h2>
            <form method="post" action="/Auth/Logout" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout-homepage">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Đăng xuất
                </button>
            </form>
        </div>
    </div>
    <div class="card-body">
        <p>Xin chào <strong>@ViewBag.Username</strong>,</p>

        @if (role == "Manager")
        {
            <div class="welcome-message manager">
                <h3>🎯 Vai trò: Quản lý</h3>
                <p>Bạn có toàn quyền quản lý hệ thống. Sử dụng menu bên trái để:</p>
                <ul>
                    <li>Quản lý giáo viên và học sinh</li>
                    <li>Quản lý tài khoản hệ thống</li>
                    <li>Quản lý lớp học</li>
                </ul>
            </div>
        }
        else if (role == "Employee")
        {
            <div class="welcome-message employee">
                <h3>📚 Vai trò: Giáo viên</h3>
                <p>Quản lý lớp học và học sinh của bạn. Sử dụng menu bên trái để:</p>
                <ul>
                    <li>Xem thông tin cá nhân</li>
                    <li>Quản lý lớp của tôi</li>
                    <li>Điểm danh học sinh</li>
                </ul>
            </div>
        }
        else if (role == "Parent")
        {
            <div class="welcome-message parent">
                <h3>👨‍👩‍👧‍👦 Vai trò: Phụ huynh</h3>
                <p>Theo dõi tiến độ học tập của con em bạn. Sử dụng menu bên trái để:</p>
                <ul>
                    <li>Xem thông tin con</li>
                    <li>Xem báo cáo điểm danh</li>
                    <li>Xem báo cáo học tập</li>
                    <li>Thanh toán học phí</li>
                </ul>
            </div>
        }
    </div>
</div>

<div class="dashboard-grid">
    <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-content">
            <div class="stat-label">Thống kê</div>
            <div class="stat-value">Cập nhật sớm</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">🔔</div>
        <div class="stat-content">
            <div class="stat-label">Thông báo</div>
            <div class="stat-value">3 mới</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">⚙️</div>
        <div class="stat-content">
            <div class="stat-label">Trạng thái</div>
            <div class="stat-value">Hoạt động</div>
        </div>
    </div>
</div>

<style>
    .btn-logout-homepage {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: #ef4444;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        font-family: inherit;
        transition: background 0.2s;
    }

    .btn-logout-homepage:hover {
        background: #dc2626;
    }

    .btn-logout-homepage svg {
        width: 16px;
        height: 16px;
    }
</style>
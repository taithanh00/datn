@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var role = ViewBag.Role as string ?? "";
}
@if (role == "Manager")
{
    <div class="dashboard-card">
        <div class="card-header">
            <h2 style="margin: 0;">📊 Realtime tổng quan phê duyệt</h2>
        </div>
        <div class="card-body" style="padding: 24px;">
            <div style="display:grid; grid-template-columns: repeat(2, minmax(240px, 1fr)); gap:12px;">
                <div style="background:#eff6ff; border-radius:10px; padding:16px;">
                    <div style="font-size:14px; color:#1d4ed8;">Chấm công chờ duyệt</div>
                    <div id="pendingAttendanceCount" style="font-size:28px; font-weight:700;">0</div>
                </div>
                <div style="background:#f5f3ff; border-radius:10px; padding:16px;">
                    <div style="font-size:14px; color:#6d28d9;">Đơn nghỉ phép chờ duyệt</div>
                    <div id="pendingLeaveCount" style="font-size:28px; font-weight:700;">0</div>
                </div>
            </div>
            <p id="managerRealtimeStatus" style="margin-top:14px; color:#64748b;">Đang kết nối realtime...</p>
            <div id="realtimeToastContainer" style="position: fixed; right: 18px; top: 80px; z-index: 9999; display:flex; flex-direction:column; gap:8px;"></div>
        </div>
    </div>

    @section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        function showToast(message) {
            const container = document.getElementById("realtimeToastContainer");
            const toast = document.createElement("div");
            toast.style.background = "#111827";
            toast.style.color = "#fff";
            toast.style.padding = "10px 12px";
            toast.style.borderRadius = "10px";
            toast.style.boxShadow = "0 6px 18px rgba(0,0,0,.2)";
            toast.style.fontSize = "13px";
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3500);
        }

        async function refreshManagerCounts() {
            const [attendanceRes, leaveRes] = await Promise.all([
                fetch("/LeaveApproval/Api/PendingAttendance"),
                fetch("/LeaveApproval/Api/PendingLeaveRequests")
            ]);
            const attendancePayload = await attendanceRes.json();
            const leavePayload = await leaveRes.json();

            document.getElementById("pendingAttendanceCount").textContent =
                attendancePayload.success ? attendancePayload.data.length : 0;
            document.getElementById("pendingLeaveCount").textContent =
                leavePayload.success ? leavePayload.data.length : 0;
        }

        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/realtime").build();
        connection.on("attendanceChanged", (event) => {
            refreshManagerCounts();
            if (event?.eventType === "attendance.created" || event?.eventType === "attendance.updated") {
                showToast("Có chấm công mới từ Employee.");
            }
        });
        connection.on("leaveRequestChanged", (event) => {
            refreshManagerCounts();
            if (event?.eventType === "leave.created") {
                showToast("Có đơn nghỉ phép mới cần duyệt.");
            }
        });
        connection.start()
            .then(() => {
                document.getElementById("managerRealtimeStatus").textContent =
                    "Realtime đang hoạt động. Số liệu sẽ tự cập nhật khi có phát sinh mới.";
            })
            .catch(() => {
                document.getElementById("managerRealtimeStatus").textContent =
                    "Không kết nối được realtime. Hệ thống vẫn có thể tải lại thủ công.";
            });

        refreshManagerCounts();
    </script>
    }
}
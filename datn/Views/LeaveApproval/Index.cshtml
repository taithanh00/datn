@{
    ViewData["Title"] = "Duyệt nghỉ phép & Chấm công";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Duyệt chấm công & nghỉ phép</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Quản lý và phê duyệt các yêu cầu từ nhân viên</p>
    </div>
</div>

<!-- Status Bar -->
<div id="managerAlert" class="page-alert mb-4" style="background: var(--bg-card); color: var(--text-muted); border-left: 4px solid var(--border);">
    <i class="fa-solid fa-circle-notch fa-spin"></i> Đang tải dữ liệu và kết nối...
</div>

<!-- Filters -->
<div class="card mb-4">
    <div style="display: flex; gap: 16px; align-items: flex-end;">
        <div class="form-group" style="margin-bottom: 0; min-width: 150px;">
            <label for="filterMonth" class="form-label">Tháng</label>
            <select id="filterMonth" class="form-select"></select>
        </div>
        <div class="form-group" style="margin-bottom: 0; min-width: 150px;">
            <label for="filterYear" class="form-label">Năm</label>
            <select id="filterYear" class="form-select"></select>
        </div>
        <button class="btn btn-primary" type="button" id="btnApplyFilter" style="height: 42px;">
            <i class="fa-solid fa-filter"></i> Lọc dữ liệu
        </button>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr; gap: 24px;">
    <!-- Attendance Section -->
    <div class="card">
        <h3 style="margin-bottom: 16px; font-size: 1.1rem; color: var(--text-main);">
            <div class="avatar" style="background: var(--primary-soft); color: var(--primary); display: inline-flex; width: 32px; height: 32px; font-size: 0.9rem; margin-right: 8px;"><i class="fa-solid fa-clock"></i></div>
            Chấm công chờ duyệt
        </h3>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nhân viên</th>
                        <th>Ngày</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Trạng thái</th>
                        <th>Phạt</th>
                        <th style="text-align: right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="pendingAttendanceBody">
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <div class="spinner"></div><p class="mt-2">Đang tải dữ liệu chấm công...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Leave Request Section -->
    <div class="card">
        <h3 style="margin-bottom: 16px; font-size: 1.1rem; color: var(--text-main);">
            <div class="avatar" style="background: rgba(251,191,36,0.15); color: var(--warning); display: inline-flex; width: 32px; height: 32px; font-size: 0.9rem; margin-right: 8px;"><i class="fa-solid fa-calendar-day"></i></div>
            Đơn nghỉ phép chờ duyệt
        </h3>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nhân viên</th>
                        <th>Từ ngày</th>
                        <th>Đến ngày</th>
                        <th>Lý do</th>
                        <th style="text-align: right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="pendingLeaveBody">
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <div class="spinner"></div><p class="mt-2">Đang tải đơn nghỉ phép...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/pages/leave-approval.js" asp-append-version="true"></script>
}

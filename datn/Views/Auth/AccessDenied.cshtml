@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SenHồng</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="~/css/pages/access-denied.css" asp-append-version="true" />
</head>
<body id="body">
    <div class="error-container">
        <div class="error-icon-wrapper">
            <img src="/images/lion_orange.png" alt="Lion" class="lion-img">
            <div class="lock-overlay">
                <i class="fa-solid fa-lock"></i>
            </div>
        </div>

        <div class="error-code">403</div>
        <h1 class="error-title">Dừng lại một chút!</h1>
        <p class="error-desc">
            Có vẻ như bạn đang cố gắng truy cập vào một khu vực không dành cho tài khoản của mình. 
            Vui lòng liên hệ Quản trị viên nếu bạn tin rằng đây là một sự nhầm lẫn.
        </p>

        <div class="user-badge">
            <img src="/images/lion_orange.png" style="width: 32px; height: 32px; border-radius: 50%; background: #eee;">
            <div class="badge-info">
                <div class="badge-name">@ViewBag.Username</div>
                <div class="badge-role">
                    @{
                        var role = ViewBag.Role ?? "User";
                        var roleDisplay = role switch { "Manager" => "Quản lý", "Employee" => "Giáo viên", "Parent" => "Phụ huynh", _ => role };
                    }
                    Vai trò: @roleDisplay
                </div>
            </div>
        </div>

        <div class="btn-group">
            <a href="javascript:history.back()" class="btn btn-ghost">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
            <a href="/" class="btn btn-primary">
                <i class="fa-solid fa-house"></i> Về trang chủ
            </a>
        </div>
    </div>

    <script src="~/js/pages/access-denied.js" asp-append-version="true"></script>
</body>
</html>

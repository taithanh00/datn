@{
    ViewData["Title"] = "Quản lý Ngày lễ";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý Ngày lễ</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Thiết lập lịch nghỉ chung và tự động tính công cho toàn trường</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 24px; margin-top: 24px;">
    <!-- Form tạo mới -->
    <div class="card">
        <h3 style="margin-bottom: 16px; font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 12px;">Thiết lập ngày lễ</h3>
        <div class="form-group">
            <label class="form-label" for="holidayName">Tên ngày lễ</label>
            <input id="holidayName" type="text" class="form-input" placeholder="Ví dụ: Giải phóng miền Nam" required />
        </div>
        <div class="form-group">
            <label class="form-label" for="holidayDate">Ngày nghỉ</label>
            <input id="holidayDate" type="date" class="form-input" required />
        </div>
        <div class="form-group">
            <label class="form-label" for="holidayDesc">Ghi chú (Tùy chọn)</label>
            <textarea id="holidayDesc" class="form-input" rows="3" placeholder="Thông tin thêm về ngày nghỉ..."></textarea>
        </div>
        
        <button id="btnCreateHoliday" type="button" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 8px;">
            <i class="fa-solid fa-calendar-check"></i> Thiết lập ngày lễ
        </button>
        
        <div id="holidayAlert" class="page-alert mt-3" style="display: none;"></div>
    </div>

    <!-- Danh sách -->
    <div class="card">
        <h3 style="margin-bottom: 16px; font-size: 1.1rem;">Danh sách ngày lễ trong năm</h3>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Ngày</th>
                        <th>Tên ngày lễ</th>
                        <th>Trạng thái</th>
                        <th style="text-align: right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="holidayTableBody">
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <div class="spinner"></div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/holidays.js" asp-append-version="true"></script>
}

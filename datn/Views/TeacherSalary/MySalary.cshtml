@model IEnumerable<datn.Models.Salary>
@{
    ViewData["Title"] = "Lương của tôi";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Lịch sử nhận lương</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Theo dõi thu nhập hàng tháng của bạn</p>
    </div>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div class="empty-state py-5">
            <i class="fa-solid fa-box-open"></i>
            <p>Bạn chưa có dữ liệu lương trong hệ thống.</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Kỳ lương</th>
                        <th>Ngày công</th>
                        <th>Thực nhận</th>
                        <th>Trạng thái</th>
                        <th style="text-align: right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>
                                <div class="badge badge-info"><i class="fa-regular fa-calendar me-1"></i> Tháng @s.PayrollPeriod.Month/@s.PayrollPeriod.Year</div>
                            </td>
                            <td><span style="font-weight: 600;">@s.WorkingDays</span> <span class="text-muted">ngày</span></td>
                            <td><span style="color: var(--success); font-weight: 700; font-size: 1.1rem;">@string.Format("{0:N0}", s.SalaryAmount) đ</span></td>
                            <td>
                                @if (s.PayrollPeriod.IsLocked)
                                {
                                    <span class="badge badge-success"><i class="fa-solid fa-check-double"></i> Đã thanh toán</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning"><i class="fa-solid fa-clock"></i> Đang chờ chốt</span>
                                }
                            </td>
                            <td style="text-align: right;">
                                <a asp-action="SalarySlip" asp-route-employeeId="@s.EmployeeId" asp-route-periodId="@s.PayrollPeriodId" class="btn btn-outline" style="padding: 6px 12px; font-size: 0.85rem;">
                                    <i class="fa-solid fa-file-invoice"></i> Xem chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@model datn.Models.Salary
@{
    ViewData["Title"] = "Phiếu lương chi tiết";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var penalties = ViewBag.Penalties as IEnumerable<datn.Models.WorkAttendance> ?? new List<datn.Models.WorkAttendance>();
    var totalPenalty = penalties.Sum(p => p.PenaltyAmount);
    var baseSalary = Model.Employee.BaseSalary ?? 0m;
    var dailyRate = baseSalary / 22m;
    var grossFromDays = (Model.WorkingDays ?? 0) * dailyRate;
}

@section Styles {
    <style>
        .slip-container {
            max-width: 800px;
            margin: 20px auto;
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            color: #333;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .slip-header {
            text-align: center;
            border-bottom: 2px solid #007bff;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .slip-header h1 { color: #007bff; margin: 0; text-transform: uppercase; font-size: 1.8rem; }
        .school-name { font-weight: bold; font-size: 1.2rem; margin-top: 5px; }
        
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }
        .info-item { border-bottom: 1px dashed #ddd; padding: 8px 0; display: flex; justify-content: space-between; }
        .info-label { color: #666; font-weight: 500; }
        .info-value { font-weight: 600; }

        .salary-calculation {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        .salary-calculation th { text-align: left; padding: 12px; background: #f8f9fa; border-bottom: 2px solid #dee2e6; }
        .salary-calculation td { padding: 12px; border-bottom: 1px solid #eee; }
        .salary-calculation .amount { text-align: right; font-family: monospace; font-size: 1.1rem; }
        
        .row-total { background: #e7f3ff; font-weight: bold; }
        .row-penalty { color: #dc3545; }
        
        .penalties-detail {
            font-size: 0.85rem;
            color: #666;
            margin-top: 20px;
            padding: 15px;
            background: #fff5f5;
            border-radius: 6px;
        }
        .penalties-detail h4 { margin-top: 0; color: #dc3545; border-bottom: 1px solid #feb2b2; padding-bottom: 5px; }

        .slip-footer {
            margin-top: 50px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            text-align: center;
        }
        .signature-box { height: 100px; margin-top: 10px; }

        @@media print {
            .no-print { display: none !important; }
            body { background: white !important; }
            .slip-container { box-shadow: none; border: 1px solid #eee; margin: 0; width: 100%; max-width: none; }
        }
    </style>
}

<div class="no-print" style="max-width: 800px; margin: 0 auto 10px auto; display: flex; justify-content: space-between;">
    <a asp-action="@(User.IsInRole("Manager") ? "Index" : "MySalary")" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left"></i> Quay lại
    </a>
    <button onclick="window.print()" class="btn btn-primary">
        <i class="fa-solid fa-print"></i> In phiếu lương
    </button>
</div>

<div class="slip-container">
    <div class="slip-header">
        <div class="school-name">HỆ THỐNG QUẢN LÝ TRƯỜNG HỌC DATN</div>
        <h1>Phiếu thanh toán tiền lương</h1>
        <div style="font-size: 1.1rem; font-weight: 600;">Tháng @Model.PayrollPeriod.Month Năm @Model.PayrollPeriod.Year</div>
    </div>

    <div class="info-grid">
        <div class="info-item">
            <span class="info-label">Mã nhân viên:</span>
            <span class="info-value">#@Model.EmployeeId</span>
        </div>
        <div class="info-item">
            <span class="info-label">Họ và tên:</span>
            <span class="info-value">@Model.Employee.FullName</span>
        </div>
        <div class="info-item">
            <span class="info-label">Vị trí:</span>
            <span class="info-value">@Model.Employee.Position</span>
        </div>
        <div class="info-item">
            <span class="info-label">Trạng thái:</span>
            <span class="info-value">@(Model.PayrollPeriod.IsLocked ? "Đã chốt" : "Dự toán")</span>
        </div>
    </div>

    <table class="salary-calculation">
        <thead>
            <tr>
                <th>Mô tả</th>
                <th style="text-align: center;">Số lượng / Tỷ lệ</th>
                <th style="text-align: right;">Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Lương cơ bản tháng (22 ngày công)</td>
                <td style="text-align: center;">100%</td>
                <td class="amount">@string.Format("{0:N0}", baseSalary) đ</td>
            </tr>
            <tr>
                <td>Ngày công thực tế (Duyệt)</td>
                <td style="text-align: center;">@Model.WorkingDays / 22</td>
                <td class="amount">@string.Format("{0:N0}", grossFromDays) đ</td>
            </tr>
            <tr class="row-penalty">
                <td>Tổng các khoản giảm trừ (Phạt đi muộn/về sớm)</td>
                <td style="text-align: center;">-</td>
                <td class="amount">- @string.Format("{0:N0}", totalPenalty) đ</td>
            </tr>
            <tr class="row-total">
                <td>TỔNG THỰC NHẬN</td>
                <td style="text-align: center;">-</td>
                <td class="amount">@string.Format("{0:N0}", Model.SalaryAmount) đ</td>
            </tr>
        </tbody>
    </table>

    @if (penalties.Any())
    {
        <div class="penalties-detail">
            <h4><i class="fa-solid fa-triangle-exclamation"></i> Chi tiết vi phạm trong tháng</h4>
            <ul style="padding-left: 20px; margin: 0;">
                @foreach (var p in penalties)
                {
                    <li>
                        <strong>@p.Date.ToString("dd/MM/yyyy"):</strong> 
                        Phạt @string.Format("{0:N0}", p.PenaltyAmount) đ 
                        <em>(@(string.IsNullOrEmpty(p.Note) ? "Đi muộn hoặc về sớm" : p.Note))</em>
                    </li>
                }
            </ul>
        </div>
    }

    <div class="slip-footer">
        <div>
            <p><strong>Người lập biểu</strong></p>
            <p style="font-size: 0.8rem; color: #888;">(Ký và ghi rõ họ tên)</p>
            <div class="signature-box"></div>
        </div>
        <div>
            <p><strong>Nhân viên xác nhận</strong></p>
            <p style="font-size: 0.8rem; color: #888;">(Ký và ghi rõ họ tên)</p>
            <div class="signature-box"></div>
        </div>
    </div>
</div>

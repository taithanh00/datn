@model datn.Models.Salary
@{
    ViewData["Title"] = "Phiếu lương chi tiết";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var penalties = ViewBag.Penalties as IEnumerable<datn.Models.WorkAttendance> ?? new List<datn.Models.WorkAttendance>();
    var totalPenalty = penalties.Sum(p => p.PenaltyAmount);
    var baseSalary = Model.Employee.BaseSalary ?? 0m;
    var dailyRate = baseSalary / 22m;
    var grossFromDays = (Model.WorkingDays ?? 0) * dailyRate;
}

<div class="page-header d-print-none">
    <div>
        <h1 class="page-title">Phiếu thanh toán tiền lương</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Chi tiết thu nhập tháng @Model.PayrollPeriod.Month/@Model.PayrollPeriod.Year</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="@(User.IsInRole("Manager") ? "Index" : "MySalary")" class="btn btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
        <button onclick="window.print()" class="btn btn-primary">
            <i class="fa-solid fa-print"></i> In phiếu lương
        </button>
    </div>
</div>

<div class="card" style="max-width: 800px; margin: 0 auto; padding: 40px;">
    <!-- Slip Header -->
    <div style="text-align: center; border-bottom: 2px solid var(--primary); padding-bottom: 24px; margin-bottom: 32px;">
        <div style="font-weight: 800; font-size: 1.25rem; color: var(--text-main); margin-bottom: 8px;">HỆ THỐNG QUẢN LÝ TRƯỜNG HỌC DATN</div>
        <h2 style="color: var(--primary); text-transform: uppercase; font-size: 1.8rem; margin: 0 0 8px 0; font-weight: 800;">Phiếu thanh toán tiền lương</h2>
        <div class="badge badge-info" style="font-size: 1rem; font-weight: 600;">Tháng @Model.PayrollPeriod.Month Năm @Model.PayrollPeriod.Year</div>
    </div>

    <!-- Employee Info -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; background: var(--bg-body); padding: 24px; border-radius: var(--radius-lg); border: 1px solid var(--border);">
        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border); padding-bottom: 8px;">
            <span class="text-muted">Mã nhân viên:</span>
            <span style="font-weight: 700; color: var(--primary);">#@Model.EmployeeId</span>
        </div>
        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border); padding-bottom: 8px;">
            <span class="text-muted">Họ và tên:</span>
            <span style="font-weight: 600;">@Model.Employee.FullName</span>
        </div>
        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border); padding-bottom: 8px;">
            <span class="text-muted">Vị trí:</span>
            <span style="font-weight: 600;">@Model.Employee.Position</span>
        </div>
        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border); padding-bottom: 8px;">
            <span class="text-muted">Trạng thái:</span>
            <span style="font-weight: 600;">
                @if (Model.PayrollPeriod.IsLocked)
                {
                    <span style="color: var(--success);"><i class="fa-solid fa-check-double"></i> Đã chốt</span>
                }
                else
                {
                    <span style="color: var(--warning);"><i class="fa-solid fa-clock"></i> Dự toán</span>
                }
            </span>
        </div>
    </div>

    <!-- Calculation Table -->
    <div class="table-container" style="margin-bottom: 32px;">
        <table style="margin: 0;">
            <thead>
                <tr>
                    <th>Mô tả</th>
                    <th style="text-align: center;">Số lượng / Tỷ lệ</th>
                    <th style="text-align: right;">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Lương cơ bản tháng (22 ngày công)</td>
                    <td style="text-align: center;"><div class="badge badge-info">100%</div></td>
                    <td style="text-align: right; font-family: monospace; font-size: 1.1rem; font-weight: 600;">@string.Format("{0:N0}", baseSalary) đ</td>
                </tr>
                <tr>
                    <td>Ngày công thực tế (Duyệt)</td>
                    <td style="text-align: center;"><div class="badge" style="background: var(--bg-body); border: 1px solid var(--border); color: var(--text-main);">@Model.WorkingDays / 22</div></td>
                    <td style="text-align: right; font-family: monospace; font-size: 1.1rem; font-weight: 600;">@string.Format("{0:N0}", grossFromDays) đ</td>
                </tr>
                <tr>
                    <td style="color: var(--danger);">Tổng các khoản giảm trừ (Phạt đi muộn/về sớm)</td>
                    <td style="text-align: center;">-</td>
                    <td style="text-align: right; font-family: monospace; font-size: 1.1rem; font-weight: 600; color: var(--danger);">- @string.Format("{0:N0}", totalPenalty) đ</td>
                </tr>
                <tr style="background: var(--primary-soft);">
                    <td style="font-weight: 800; color: var(--primary); font-size: 1.1rem;">TỔNG THỰC NHẬN</td>
                    <td style="text-align: center;">-</td>
                    <td style="text-align: right; font-family: monospace; font-size: 1.25rem; font-weight: 800; color: var(--primary);">@string.Format("{0:N0}", Model.SalaryAmount) đ</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Penalties Detail -->
    @if (penalties.Any())
    {
        <div style="background: rgba(248,113,113,0.1); border-left: 4px solid var(--danger); border-radius: var(--radius-sm); padding: 16px; margin-bottom: 32px;">
            <h4 style="color: var(--danger); font-size: 1rem; font-weight: 700; margin-bottom: 12px; border-bottom: 1px solid rgba(248,113,113,0.2); padding-bottom: 8px;">
                <i class="fa-solid fa-triangle-exclamation"></i> Chi tiết vi phạm trong tháng
            </h4>
            <ul style="margin: 0; padding-left: 20px; color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">
                @foreach (var p in penalties)
                {
                    <li>
                        <strong>@p.Date.ToString("dd/MM/yyyy"):</strong> 
                        Phạt <span style="color: var(--danger); font-weight: 600;">@string.Format("{0:N0}", p.PenaltyAmount) đ</span> 
                        <em>(@(string.IsNullOrEmpty(p.Note) ? "Đi muộn hoặc về sớm" : p.Note))</em>
                    </li>
                }
            </ul>
        </div>
    }

    <!-- Footer -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; text-align: center; margin-top: 60px;">
        <div>
            <div style="font-weight: 700; color: var(--text-main);">Người lập biểu</div>
            <div class="text-muted" style="font-size: 0.8rem; margin-top: 4px;">(Ký và ghi rõ họ tên)</div>
            <div style="height: 120px;"></div>
        </div>
        <div>
            <div style="font-weight: 700; color: var(--text-main);">Nhân viên xác nhận</div>
            <div class="text-muted" style="font-size: 0.8rem; margin-top: 4px;">(Ký và ghi rõ họ tên)</div>
            <div style="height: 120px;"></div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        @@media print {
            body { background: white !important; }
            .d-print-none { display: none !important; }
            .card { box-shadow: none !important; border: none !important; padding: 0 !important; max-width: 100% !important; margin: 0 !important; }
            * { -webkit-print-color-adjust: exact !important; color-adjust: exact !important; print-color-adjust: exact !important; }
        }
    </style>
}

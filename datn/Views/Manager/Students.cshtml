@{
    ViewData["Title"] = "Học sinh";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Quản lý Học sinh</h1>
    <div class="page-actions">
        <div class="search-bar">
            <i class="fa-solid fa-search"></i>
            <input type="text" id="searchStudents" placeholder="Tìm kiếm học sinh..." />
        </div>
        <button class="btn btn-primary" id="btnCreateStudent">
            <i class="fa-solid fa-plus"></i> Thêm học sinh
        </button>
    </div>
</div>

<div class="card">
    <div class="table-container">
        <table id="studentsTable">
            <thead>
                <tr>
                    <th class="sticky-col first-col">STT</th>
                    <th class="sticky-col second-col">Mã HS</th>
                    <th class="sticky-col third-col">Ảnh</th>
                    <th class="sticky-col fourth-col">Họ và tên</th>
                    <th>Trạng thái</th>
                    <th>Giới tính</th>
                    <th>Ngày sinh</th>
                    <th>Tên Bố</th>
                    <th>Tên Mẹ</th>
                    <th>Địa chỉ</th>
                    <th>Lớp</th>
                    <th>Ngày nhập học</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody id="studentsTableBody">
                <tr class="loading-row">
                    <td colspan="14" style="text-align:center; padding:40px;">
                        <div class="spinner"></div>
                        <p class="text-muted">Đang tải dữ liệu...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Overlay -->
<div class="modal-overlay" id="modalOverlay"></div>

<!-- Slide-out Panel -->
<div class="slide-panel" id="slidePanel">
    <div class="slide-panel-header">
        <h3 id="panelTitle">Thông tin học sinh</h3>
        <button class="close-btn" id="closePanelBtn">
            <i class="fa-solid fa-xmark" style="font-size:1.2rem;"></i>
        </button>
    </div>
    <div class="slide-panel-body">
        <form id="editStudentForm">
            <input type="hidden" id="studentId" />

            <div class="form-section">
                <h4>Thông tin cơ bản</h4>
                <div class="form-group" style="text-align:center; margin-bottom:24px;">
                    <div class="avatar-upload-wrapper">
                        <div class="avatar-preview-container" onclick="document.getElementById('avatarFile').click()">
                            <img id="avatarPreview" src="/images/lion_orange.png" alt="Avatar Preview">
                            <div class="avatar-overlay">
                                <i class="fa-solid fa-camera"></i>
                                <span>THAY ĐỔI</span>
                            </div>
                        </div>
                        <input type="file" id="avatarFile" name="Avatar" accept="image/*" hidden onchange="previewAvatar(this)">
                        <p class="text-muted small mt-2">Nhấp vào ảnh để thay đổi</p>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="firstName">Tên</label>
                    <input type="text" id="firstName" name="FirstName" class="form-control" placeholder="Nhập tên" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="lastName">Họ</label>
                    <input type="text" id="lastName" name="LastName" class="form-control" placeholder="Nhập họ" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="gender">Giới tính</label>
                    <select id="gender" name="Gender" class="form-control">
                        <option value="">-- Chọn --</option>
                        <option value="true">Nam</option>
                        <option value="false">Nữ</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="dateOfBirth">Ngày sinh</label>
                    <input type="date" id="dateOfBirth" name="DateOfBirth" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="address">Địa chỉ</label>
                    <textarea id="address" name="Address" class="form-control" rows="2" placeholder="Nhập địa chỉ"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="fatherName">Tên bố</label>
                            <input type="text" id="fatherName" name="FatherName" class="form-control" placeholder="Họ tên bố" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="motherName">Tên mẹ</label>
                            <input type="text" id="motherName" name="MotherName" class="form-control" placeholder="Họ tên mẹ" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="status">Trạng thái</label>
                    <select id="status" name="Status" class="form-control">
                        <option value="0">Đang học</option>
                        <option value="1">Đã nghỉ</option>
                    </select>
                </div>
            </div>

            <div class="form-section">
                <h4>Thông tin học tập</h4>
                <div class="form-group">
                    <label class="form-label" for="classId">Lớp học</label>
                    <select id="classId" name="ClassId" class="form-control">
                        <option value="">-- Chọn lớp --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="enrollDate">Ngày nhập học</label>
                    <input type="date" id="enrollDate" name="EnrollDate" class="form-control" />
                </div>
            </div>

            <div id="editFormAlert" class="form-alert" style="display:none;"></div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="fa-solid fa-cloud-arrow-up"></i> Lưu thay đổi
                </button>
                <button type="button" class="btn-delete" id="deleteStudentBtn" style="display:none;">
                    <i class="fa-solid fa-trash"></i> Xóa học sinh
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/students.css" asp-append-version="true" />
}

<!-- Duplicate Confirmation Modal -->
<div class="modal-overlay" id="duplicateModalOverlay" style="z-index: 1001;"></div>
<div class="confirm-modal" id="duplicateModal">
    <div class="confirm-modal-header">
        <i class="fa-solid fa-triangle-exclamation text-warning"></i>
        <h4>Cảnh báo trùng lặp</h4>
    </div>
    <div class="confirm-modal-body">
        <p id="duplicateMessage"></p>
    </div>
    <div class="confirm-modal-footer">
        <button type="button" class="btn-secondary" id="viewExistingBtn">Xem hồ sơ cũ</button>
        <button type="button" class="btn-primary" id="forceCreateBtn">Vẫn tạo mới</button>
        <button type="button" class="btn-link" id="cancelDuplicateBtn">Hủy</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/students.js" asp-append-version="true"></script>
}

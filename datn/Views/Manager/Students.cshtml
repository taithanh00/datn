@{
    ViewData["Title"] = "Học sinh";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Quản lý Học sinh</h1>
    <div class="page-actions">
        <div class="search-bar">
            <i class="fa-solid fa-search"></i>
            <input type="text" id="searchStudents" placeholder="Tìm kiếm học sinh..." />
        </div>
        <button class="btn btn-primary" id="btnCreateStudent">
            <i class="fa-solid fa-plus"></i> Thêm học sinh
        </button>
    </div>
</div>

<div class="card">
    <div class="table-container">
        <table id="studentsTable">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Ảnh</th>
                    <th>Họ và tên</th>
                    <th>Giới tính</th>
                    <th>Ngày sinh</th>
                    <th>Lớp</th>
                    <th>Ngày nhập học</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody id="studentsTableBody">
                <tr class="loading-row">
                    <td colspan="8" style="text-align:center; padding:40px;">
                        <div class="spinner"></div>
                        <p class="text-muted">Đang tải dữ liệu...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Overlay -->
<div class="modal-overlay" id="modalOverlay"></div>

<!-- Slide-out Panel -->
<div class="slide-panel" id="slidePanel">
    <div class="slide-panel-header">
        <h3 id="panelTitle">Thông tin học sinh</h3>
        <button class="close-btn" id="closePanelBtn">
            <i class="fa-solid fa-xmark" style="font-size:1.2rem;"></i>
        </button>
    </div>
    <div class="slide-panel-body">
        <form id="editStudentForm">
            <input type="hidden" id="studentId" />

            <div class="form-section">
                <h4>Thông tin cơ bản</h4>
                <div class="form-group" style="text-align:center; margin-bottom:20px;">
                    <div class="avatar-upload-container">
                        <img id="avatarPreview" src="/images/lion_orange.png" alt="Avatar" style="width:100px; height:100px; object-fit:cover;" />
                        <input type="file" id="avatarFile" name="Avatar" class="form-control" accept="image/*" onchange="previewAvatar(this)" style="margin-top:12px;" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="firstName">Tên</label>
                    <input type="text" id="firstName" name="FirstName" class="form-control" placeholder="Nhập tên" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="lastName">Họ</label>
                    <input type="text" id="lastName" name="LastName" class="form-control" placeholder="Nhập họ" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="gender">Giới tính</label>
                    <select id="gender" name="Gender" class="form-control">
                        <option value="">-- Chọn --</option>
                        <option value="true">Nam</option>
                        <option value="false">Nữ</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="dateOfBirth">Ngày sinh</label>
                    <input type="date" id="dateOfBirth" name="DateOfBirth" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="address">Địa chỉ</label>
                    <textarea id="address" name="Address" class="form-control" rows="3" placeholder="Nhập địa chỉ"></textarea>
                </div>
            </div>

            <div class="form-section">
                <h4>Thông tin học tập</h4>
                <div class="form-group">
                    <label class="form-label" for="classId">Lớp học</label>
                    <select id="classId" name="ClassId" class="form-control">
                        <option value="">-- Chọn lớp --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="enrollDate">Ngày nhập học</label>
                    <input type="date" id="enrollDate" name="EnrollDate" class="form-control" />
                </div>
            </div>

            <div id="editFormAlert" class="form-alert" style="display:none;"></div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="fa-solid fa-cloud-arrow-up"></i> Lưu thay đổi
                </button>
                <button type="button" class="btn-delete" id="deleteStudentBtn" style="display:none;">
                    <i class="fa-solid fa-trash"></i> Xóa học sinh
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/students.js" asp-append-version="true"></script>
}

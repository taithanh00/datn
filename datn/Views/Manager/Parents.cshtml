@{
    ViewData["Title"] = "Phụ huynh";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h1 class="page-title">Quản lý Phụ huynh</h1>
    <div class="page-actions">
        <div class="search-bar">
            <i class="fa-solid fa-search"></i>
            <input type="text" id="searchParents" placeholder="Tìm kiếm tên hoặc số điện thoại..." />
        </div>
        <button class="btn btn-primary" id="btnCreateParent">
            <i class="fa-solid fa-user-plus"></i> Thêm phụ huynh
        </button>
    </div>
</div>

<div class="card">
    <div class="table-container">
        <table id="parentsTable">
            <thead>
                <tr>
                    <th class="sticky-col first-col">STT</th>
                    <th class="sticky-col second-col">Ảnh</th>
                    <th class="sticky-col third-col">Họ và tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Địa chỉ</th>
                    <th>Danh sách con</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody id="parentsTableBody">
                <tr class="loading-row">
                    <td colspan="9" style="text-align:center; padding:40px;">
                        <div class="spinner"></div>
                        <p class="text-muted">Đang tải dữ liệu...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Overlay -->
<div class="modal-overlay" id="modalOverlay"></div>

<!-- Slide-out Panel -->
<div class="slide-panel" id="slidePanel">
    <div class="slide-panel-header">
        <h3 id="panelTitle">Thêm phụ huynh mới</h3>
        <button class="close-btn" id="closePanelBtn">
            <i class="fa-solid fa-xmark" style="font-size:1.2rem;"></i>
        </button>
    </div>
    <div class="slide-panel-body">
        <form id="parentForm" enctype="multipart/form-data">
            <input type="hidden" id="parentId" name="Id" />

            <div class="form-section">
                <h4><i class="fa-solid fa-circle-user"></i> Thông tin tài khoản</h4>
                <div class="form-group" style="text-align:center; margin-bottom:24px;">
                    <div class="avatar-upload-wrapper">
                        <div class="avatar-preview-container" onclick="document.getElementById('avatarInput').click()">
                            <img id="avatarPreview" src="/images/lion_orange.png" alt="Preview" />
                            <div class="avatar-overlay">
                                <i class="fa-solid fa-camera"></i>
                                <span>THAY ĐỔI</span>
                            </div>
                        </div>
                        <input type="file" id="avatarInput" name="Avatar" hidden accept="image/*" onchange="previewImage(this)" />
                        <p class="text-muted small mt-2">Ảnh đại diện phụ huynh</p>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="username">Tên đăng nhập</label>
                    <input type="text" id="username" name="Username" class="form-control" required placeholder="Ví dụ: ph_nguyenvan" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="email">Email liên hệ</label>
                    <input type="email" id="email" name="Email" class="form-control" required placeholder="Ví dụ: phuhuynh@gmail.com" />
                </div>
                <div class="form-group" id="passwordFieldGroup">
                    <label class="form-label" for="password">Mật khẩu</label>
                    <input type="password" id="password" name="Password" class="form-control" placeholder="Để trống nếu không muốn đổi" />
                    <small class="text-muted" id="passwordNote">Mặc định: 123456</small>
                </div>
            </div>

            <div class="form-section">
                <h4><i class="fa-solid fa-address-card"></i> Thông tin cá nhân</h4>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="lastName">Họ</label>
                            <input type="text" id="lastName" name="LastName" class="form-control" required placeholder="Nguyễn" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="firstName">Tên</label>
                            <input type="text" id="firstName" name="FirstName" class="form-control" required placeholder="Văn A" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="phone">Số điện thoại</label>
                    <input type="text" id="phone" name="Phone" class="form-control" placeholder="Số điện thoại liên hệ" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="address">Địa chỉ</label>
                    <textarea id="address" name="Address" class="form-control" rows="2" placeholder="Địa chỉ thường trú"></textarea>
                </div>
            </div>

            <!-- Linked Students Section (Only show when editing) -->
            <div id="linkedStudentsSection" class="form-section" style="display:none;">
                <h4>
                    <i class="fa-solid fa-users"></i> Danh sách con
                    <button type="button" class="btn-add-child" onclick="showLinkStudentModal()">
                        <i class="fa-solid fa-plus"></i> Thêm con
                    </button>
                </h4>
                <div id="linkedStudentsList" class="linked-students-list">
                    <!-- Linked students will appear here -->
                </div>
            </div>

            <div id="formAlert" class="form-alert" style="display:none;"></div>

            <div class="form-actions">
                <button type="button" class="btn-save" onclick="saveParent()" id="saveParentBtn">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu thông tin
                </button>
                <button type="button" class="btn-delete" id="deleteParentBtn" style="display:none;" onclick="deleteCurrentParent()">
                    <i class="fa-solid fa-trash"></i> Xóa phụ huynh
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Overlay for Link Student -->
<div class="modal-overlay" id="linkModalOverlay" style="z-index: 1001;"></div>

<!-- Modal Link Student -->
<div class="confirm-modal" id="linkStudentModal">
    <div class="confirm-modal-header" style="text-align: left; margin-bottom: 16px;">
        <h4 style="display: flex; justify-content: space-between; align-items: center; font-size: 1.1rem;">
            <span><i class="fa-solid fa-link me-2"></i>Liên kết Học sinh</span>
            <i class="fa-solid fa-xmark text-muted" style="font-size: 1rem; cursor: pointer;" onclick="closeLinkStudentModal()"></i>
        </h4>
    </div>
    <div class="confirm-modal-body" style="text-align: left;">
        <div class="form-group">
            <label class="form-label">Tìm học sinh</label>
            <div class="search-bar" style="min-width: 100%; margin-bottom: 12px;">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="studentSearchInput" placeholder="Nhập tên hoặc mã HS...">
            </div>
            <div id="studentSearchResults" class="list-group" style="max-height: 200px; overflow-y: auto;">
                <!-- Results here -->
            </div>
        </div>
        <div id="linkDetailSection" style="display:none; margin-top: 16px; padding-top: 16px; border-top: 1px dashed var(--border);">
            <div style="background: var(--bg-main); padding: 12px; border-radius: 8px; margin-bottom: 12px;">
                <span id="selectedStudentName" class="fw-bold"></span>
                <span id="selectedStudentCode" class="text-muted small"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Mối quan hệ</label>
                <select id="linkRelationship" class="form-control">
                    <option value="Bố">Bố</option>
                    <option value="Mẹ">Mẹ</option>
                    <option value="Người giám hộ">Người giám hộ</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>
        </div>
    </div>
    <div class="confirm-modal-footer" style="flex-direction: row; justify-content: flex-end; gap: 8px;">
        <button class="btn-secondary" onclick="closeLinkStudentModal()" style="width: auto; padding: 10px 20px;">Đóng</button>
        <button class="btn-primary" id="confirmLinkBtn" onclick="confirmLinkStudent()" disabled style="width: auto; padding: 10px 20px;">
            <i class="fa-solid fa-link"></i> Xác nhận liên kết
        </button>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/parents.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/pages/parents.js" asp-append-version="true"></script>
}

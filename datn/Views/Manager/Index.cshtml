@{
    ViewData["Title"] = "Bảng điều khiển";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="stats-grid">
    <div class="card stat-card">
        <div class="d-flex align-center gap-2">
            <div class="avatar" style="background:var(--primary);">
                <i class="fa-solid fa-user-graduate"></i>
            </div>
            <div>
                <div class="stat-title">Học sinh</div>
                <div class="stat-value" id="statStudents">...</div>
            </div>
        </div>
    </div>
    <div class="card stat-card">
        <div class="d-flex align-center gap-2">
            <div class="avatar" style="background:#F59E0B;">
                <i class="fa-solid fa-chalkboard-user"></i>
            </div>
            <div>
                <div class="stat-title">Giáo viên</div>
                <div class="stat-value" id="statTeachers">...</div>
            </div>
        </div>
    </div>
    <div class="card stat-card">
        <div class="d-flex align-center gap-2">
            <div class="avatar" style="background:var(--success);">
                <i class="fa-solid fa-hand-holding-dollar"></i>
            </div>
            <div>
                <div class="stat-title">Doanh thu tháng</div>
                <div class="stat-value" id="statRevenue">...</div>
            </div>
        </div>
    </div>
    <div class="card stat-card">
        <div class="d-flex align-center gap-2">
            <div class="avatar" style="background:var(--danger);">
                <i class="fa-solid fa-envelope-open-text"></i>
            </div>
            <div>
                <div class="stat-title">Đơn nghỉ chờ duyệt</div>
                <div class="stat-value" id="statPendingLeaves">...</div>
            </div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:24px;">
    <div class="card">
        <h3 style="margin-bottom:16px;">Xu hướng doanh thu</h3>
        <div style="position:relative; height:250px;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>
    <div class="card">
        <h3 style="margin-bottom:16px;">Sĩ số hôm nay</h3>
        <div style="height:200px; display:flex; align-items:center; justify-content:center;">
            <canvas id="attendanceChart"></canvas>
        </div>
        <div id="attendanceInfo" class="text-muted" style="text-align:center; font-size:0.85rem; margin-top:12px;">Đang tính toán...</div>
    </div>
</div>

<div class="card">
    <div class="d-flex align-center justify-between mb-2">
        <h3>Đơn nghỉ phép mới nhất</h3>
        <a href="/LeaveApproval" class="btn btn-outline" data-transition>Xem tất cả</a>
    </div>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Giáo viên</th>
                    <th>Thời gian nghỉ</th>
                    <th>Lý do</th>
                    <th style="text-align:right;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="latestLeavesTable">
                <tr><td colspan="4" class="text-muted" style="text-align:center; padding:32px;">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/pages/manager-dashboard.js" asp-append-version="true"></script>
}

@{
    ViewData["Title"] = "Chương trình học";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Chương trình học</h1>
    <button class="btn btn-primary" id="resetFormBtn" type="button"><i class="fa-solid fa-plus"></i> Tạo chương trình</button>
</div>

<div class="card">
    <div id="alert" class="page-alert" style="display:none;"></div>
    <div class="table-container">
        <table id="curriculumsTable">
            <thead><tr><th>Tên chương trình</th><th>Môn học</th><th>Độ tuổi</th><th>Mô tả</th><th>Thao tác</th></tr></thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>

    <form id="entityForm" class="mt-3" style="border-top:1px solid var(--border); padding-top:24px;">
        <input type="hidden" id="entityId" />
        <div style="display:grid; grid-template-columns:2fr 1fr; gap:16px;">
            <div class="form-group"><label class="form-label">Tiêu đề</label><input id="title" type="text" class="form-input" required /></div>
            <div class="form-group"><label class="form-label">Môn học</label><select id="subjectId" class="form-select"></select></div>
        </div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div class="form-group"><label class="form-label">Tuổi từ</label><input id="ageFrom" type="number" class="form-input" /></div>
            <div class="form-group"><label class="form-label">Tuổi đến</label><input id="ageTo" type="number" class="form-input" /></div>
        </div>
        <div class="form-group"><label class="form-label">Mô tả</label><input id="description" type="text" class="form-input" /></div>
        <div class="form-group"><label class="form-label">Nội dung chi tiết</label><textarea id="content" class="form-input" rows="5"></textarea></div>
        <div class="d-flex gap-1 mt-1">
            <button type="submit" class="btn btn-primary" id="saveBtn">Lưu chương trình</button>
            <button type="button" class="btn btn-outline" id="clearBtn">Làm mới</button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/curriculums.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/pages/curriculums.js" asp-append-version="true"></script>
}

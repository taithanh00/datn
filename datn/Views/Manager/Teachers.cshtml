@{
    ViewData["Title"] = "Danh sách Giáo viên";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/teachers.css" asp-append-version="true" />
}

<div class="dashboard-card">
    <div class="card-header">
        <h2 style="margin: 0;">👨‍🏫 Quản lý Giáo viên</h2>
        <button class="btn-create" id="btnCreateTeacher">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            Thêm giáo viên
        </button>
    </div>

    <div class="card-body">
        <!-- Teachers Table -->
        <div class="table-responsive">
            <table class="teachers-table" id="teachersTable">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Họ và tên</th>
                        <th>Điện thoại</th>
                        <th>Chức vụ</th>
                        <th>Lương cơ bản</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody id="teachersTableBody">
                    <tr class="loading-row">
                        <td colspan="6" style="text-align: center; padding: 40px;">
                            <div class="spinner"></div>
                            <p>Đang tải dữ liệu...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Overlay -->
<div class="modal-overlay" id="modalOverlay"></div>

<!-- Slide-out Panel for Edit -->
<div class="slide-panel" id="slidePanel">
    <div class="slide-panel-header">
        <h3 id="panelTitle">Thông tin giáo viên</h3>
        <button class="close-btn" id="closePanelBtn">
            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <div class="slide-panel-body">
        <form id="editTeacherForm" class="edit-form">
            <input type="hidden" id="teacherId" />

            <div class="form-section">
                <h4>Thông tin cơ bản</h4>

                <div class="form-group mb-4 text-center">
                    <label>Ảnh đại diện</label>
                    <div class="avatar-upload-container">
                        <img id="avatarPreview" src="/images/lion_blue.png" alt="Avatar Preview" class="img-thumbnail rounded-circle mb-2" style="width: 120px; height: 120px; object-fit: cover;" />
                        <input type="file" id="avatarFile" name="Avatar" class="form-control" accept="image/*" onchange="previewAvatar(this)" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="fullName">Họ và tên</label>
                    <input type="text" id="fullName" name="FullName" class="form-control" placeholder="Nhập họ và tên" required />
                </div>

                <div class="form-group">
                    <label for="phone">Điện thoại</label>
                    <input type="tel" id="phone" name="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                </div>

                <div class="form-group">
                    <label for="position">Chức vụ</label>
                    <input type="text" id="position" name="Position" class="form-control" placeholder="Nhập chức vụ (vd: Giáo viên môn Toán)" />
                </div>

                <div class="form-group">
                    <label for="baseSalary">Lương cơ bản</label>
                    <input type="number" id="baseSalary" name="BaseSalary" class="form-control" placeholder="Nhập lương cơ bản" step="0.01" />
                </div>
            </div>

            <!-- Alert Messages -->
            <div id="editFormAlert" class="form-alert" style="display: none;"></div>

            <!-- Action Buttons -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M5.5 13a3.5 3.5 0 01-.369-6.98 4 4 0 117.753-1.3A4.5 4.5 0 1113.5 13H11V9.413l1.293 1.293a1 1 0 001.414-1.414l-3-3a1 1 0 00-1.414 0l-3 3a1 1 0 001.414 1.414L9 9.414V13H5.5z" />
                    </svg>
                    Lưu thay đổi
                </button>
                <button type="button" class="btn-delete" id="deleteTeacherBtn" style="display: none;">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    Xóa giáo viên
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/teachers.js" asp-append-version="true"></script>
}

@{
    ViewData["Title"] = "Nhân sự";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Quản lý Nhân sự</h1>
    <div class="page-actions">
        <div class="search-bar">
            <i class="fa-solid fa-search"></i>
            <input type="text" id="searchTeachers" placeholder="Tìm kiếm nhân sự..." />
        </div>
        <button class="btn btn-primary" id="btnCreateTeacher">
            <i class="fa-solid fa-plus"></i> Thêm giáo viên
        </button>
    </div>
</div>

<div class="card">
    <div class="table-container">
        <table id="teachersTable">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Họ và tên</th>
                    <th>Điện thoại</th>
                    <th>Chức vụ</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody id="teachersTableBody">
                <tr class="loading-row">
                    <td colspan="6" style="text-align:center; padding:40px;">
                        <div class="spinner"></div>
                        <p class="text-muted">Đang tải dữ liệu...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="modalOverlay"></div>

<div class="slide-panel" id="slidePanel">
    <div class="slide-panel-header">
        <h3 id="panelTitle">Thông tin giáo viên</h3>
        <button class="close-btn" id="closePanelBtn">
            <i class="fa-solid fa-xmark" style="font-size:1.2rem;"></i>
        </button>
    </div>
    <div class="slide-panel-body">
        <form id="editTeacherForm">
            <input type="hidden" id="teacherId" />

            <div class="form-section">
                <h4>Thông tin tài khoản</h4>
                <div class="form-group" id="usernameGroup">
                    <label class="form-label" for="username">Tên đăng nhập <span class="text-danger">*</span></label>
                    <input type="text" id="username" name="Username" class="form-control" placeholder="Nhập tên đăng nhập" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="email">Email <span class="text-danger">*</span></label>
                    <input type="email" id="email" name="Email" class="form-control" placeholder="Nhập email" required />
                </div>
                <div class="form-group" id="passwordGroup">
                    <label class="form-label" for="password">Mật khẩu</label>
                    <input type="password" id="password" name="Password" class="form-control" placeholder="Mặc định: 123456" />
                </div>
            </div>

            <div class="form-section">
                <h4>Thông tin cá nhân</h4>
                <div class="form-group" style="text-align:center; margin-bottom:20px;">
                    <div class="avatar-upload-container">
                        <img id="avatarPreview" src="/images/lion_blue.png" alt="Avatar" style="width:100px; height:100px; object-fit:cover;" />
                        <input type="file" id="avatarFile" name="Avatar" class="form-control" accept="image/*" onchange="previewAvatar(this)" style="margin-top:12px;" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="fullName">Họ và tên</label>
                    <input type="text" id="fullName" name="FullName" class="form-control" placeholder="Nhập họ và tên" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="phone">Điện thoại</label>
                    <input type="tel" id="phone" name="Phone" class="form-control" placeholder="Nhập SĐT" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="position">Chức vụ</label>
                    <input type="text" id="position" name="Position" class="form-control" placeholder="VD: Giáo viên" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="baseSalary">Lương cơ bản</label>
                    <input type="number" id="baseSalary" name="BaseSalary" class="form-control" step="0.01" />
                </div>
            </div>

            <div id="editFormAlert" class="form-alert" style="display:none;"></div>

            <div class="form-actions">
                <button type="submit" class="btn-save"><i class="fa-solid fa-cloud-arrow-up"></i> Lưu</button>
                <button type="button" class="btn-delete" id="deleteTeacherBtn" style="display:none;">
                    <i class="fa-solid fa-trash"></i> Xóa
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/teachers.js" asp-append-version="true"></script>
}

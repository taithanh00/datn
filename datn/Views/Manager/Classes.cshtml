@{
    ViewData["Title"] = "Lớp học";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    @Html.AntiForgeryToken()
    <h1 class="page-title">Quản lý Lớp học</h1>
    <div class="page-actions">
        <button class="btn btn-primary" id="resetClassFormBtn" type="button">
            <i class="fa-solid fa-plus"></i> Tạo lớp mới
        </button>
    </div>
</div>

<div class="card">
    <div class="d-flex align-center justify-between mb-2">
        <h3>Danh sách lớp học</h3>
    </div>
    <div id="classAlert" style="display:none; padding:12px; border-radius:8px; margin-bottom:16px; font-size:0.85rem;"></div>
    <div class="table-container">
        <table id="classesTable">
            <thead>
                <tr>
                    <th>Lớp</th>
                    <th>Độ tuổi</th>
                    <th>Niên khóa</th>
                    <th>Sĩ số</th>
                    <th>Giáo viên</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="classesTableBody"></tbody>
        </table>
    </div>

    <form id="classForm" class="mt-3" style="border-top:1px solid var(--border); padding-top:24px;">
        <input type="hidden" id="classId" />
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div class="form-group">
                <label class="form-label" for="className">Tên lớp</label>
                <input id="className" type="text" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label" for="schoolYear">Niên khóa</label>
                <input id="schoolYear" type="text" class="form-input" placeholder="2025-2026" />
            </div>
        </div>
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px;">
            <div class="form-group">
                <label class="form-label" for="ageFrom">Tuổi từ</label>
                <input id="ageFrom" type="number" min="1" class="form-input" />
            </div>
            <div class="form-group">
                <label class="form-label" for="ageTo">Tuổi đến</label>
                <input id="ageTo" type="number" min="1" class="form-input" />
            </div>
            <div class="form-group">
                <label class="form-label" for="maxCapacity">Sĩ số tối đa</label>
                <input id="maxCapacity" type="number" min="1" class="form-input" placeholder="Mặc định: 25" />
            </div>
        </div>
        <div class="d-flex gap-1 mt-1">
            <button type="submit" class="btn btn-primary" id="saveClassBtn">Lưu lớp học</button>
            <button type="button" class="btn btn-outline" id="clearClassBtn">Làm mới</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/pages/classes.js" asp-append-version="true"></script>
}

@{
    ViewData["Title"] = "Danh mục môn học";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    @Html.AntiForgeryToken()
    <h1 class="page-title">Quản lý Danh mục môn học</h1>
    <div class="page-actions">
        <button class="btn btn-primary" id="resetSubjectFormBtn" type="button">
            <i class="fa-solid fa-plus"></i> Tạo môn mới
        </button>
    </div>
</div>

<div class="card">
    <div class="d-flex align-center justify-between mb-2">
        <h3>Danh mục môn học</h3>
    </div>
    <div id="subjectAlert" style="display:none; padding:12px; border-radius:8px; margin-bottom:16px; font-size:0.85rem;"></div>
    <div class="table-container">
        <table id="subjectsTable">
            <thead>
                <tr>
                    <th>Mã môn</th>
                    <th>Tên môn</th>
                    <th>Mô tả</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="subjectsTableBody"></tbody>
        </table>
    </div>

    <form id="subjectForm" class="mt-3" style="border-top:1px solid var(--border); padding-top:24px;">
        <input type="hidden" id="subjectId" />
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div class="form-group">
                <label class="form-label" for="subjectCode">Mã môn</label>
                <input id="subjectCode" type="text" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label" for="subjectName">Tên môn</label>
                <input id="subjectName" type="text" class="form-input" required />
            </div>
        </div>
        <div class="form-group">
            <label class="form-label" for="subjectDescription">Mô tả</label>
            <textarea id="subjectDescription" class="form-input" rows="3"></textarea>
        </div>
        <div class="form-group" style="display:flex; align-items:center; gap:8px;">
            <input id="subjectIsActive" type="checkbox" checked />
            <label for="subjectIsActive" style="font-size:0.9rem;">Đang sử dụng</label>
        </div>
        <div class="d-flex gap-1 mt-1">
            <button type="submit" class="btn btn-primary" id="saveSubjectBtn">Lưu môn học</button>
            <button type="button" class="btn btn-outline" id="clearSubjectBtn">Làm mới</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/pages/classes.js" asp-append-version="true"></script>
}

@{
    ViewData["Title"] = "Kế hoạch giảng dạy";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Kế hoạch giảng dạy</h1>
</div>

<div class="card">
    <div id="alert" class="page-alert" style="display:none;"></div>
    <form id="planForm" class="mb-3">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div class="form-group"><label class="form-label">Lớp học</label><select id="classId" class="form-select" required onchange="loadPlans()"></select></div>
            <div class="form-group"><label class="form-label">Chương trình học</label><select id="curriculumId" class="form-select" required></select></div>
        </div>
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px;">
            <div class="form-group"><label class="form-label">Bắt đầu</label><input id="startDate" type="date" class="form-input" required /></div>
            <div class="form-group"><label class="form-label">Kết thúc</label><input id="endDate" type="date" class="form-input" /></div>
            <div class="form-group"><label class="form-label">Trạng thái</label>
                <select id="status" class="form-select">
                    <option value="Planned">Đã lên lịch</option>
                    <option value="InProgress">Đang thực hiện</option>
                    <option value="Completed">Hoàn thành</option>
                </select>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Lưu kế hoạch</button>
    </form>

    <div class="table-container mt-3" style="border-top:1px solid var(--border); padding-top:24px;">
        <table id="plansTable">
            <thead><tr><th>Lớp</th><th>Chương trình</th><th>Bắt đầu</th><th>Kết thúc</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/teaching-plans.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/pages/teaching-plans.js" asp-append-version="true"></script>
}

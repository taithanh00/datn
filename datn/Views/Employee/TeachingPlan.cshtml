@{
    ViewData["Title"] = "Kế hoạch giảng dạy";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Kế hoạch giảng dạy của Lớp</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Xem các chương trình học và chủ đề giáo dục mà lớp bạn đang thực hiện.</p>
    </div>
</div>

<div class="card">
    <div id="alert" class="page-alert" style="display:none;"></div>
    <div class="table-container">
        <table id="teachingPlansTable">
            <thead>
                <tr>
                    <th>Lớp</th>
                    <th>Chương trình/Chủ đề</th>
                    <th>Thời gian</th>
                    <th>Trạng thái</th>
                    <th style="text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <tr><td colspan="5" class="text-center text-muted" style="padding: 40px;"><div class="spinner"></div></td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal xem chi tiết -->
<div class="modal-overlay" id="modalOverlay">
    <div class="modal-card" style="width: 800px; max-width: 95vw;">
        <div class="modal-header">
            <div class="modal-title" id="modalTitle">Chi tiết chương trình</div>
            <button class="modal-close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="max-height: 60vh; overflow-y: auto; padding-right: 8px;">
            <div style="margin-bottom: 20px;">
                <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: 8px;">Mô tả:</h4>
                <p id="modalDescription" class="text-muted" style="font-size: 0.9rem; line-height: 1.5;"></p>
            </div>
            <div>
                <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: 8px;">Nội dung giảng dạy chi tiết:</h4>
                <div id="modalContent" style="white-space: pre-wrap; background: var(--bg-body); padding: 16px; border-radius: var(--radius-sm); border: 1px solid var(--border); font-size: 0.9rem; line-height: 1.6; color: var(--text-main);"></div>
            </div>
        </div>
        <div class="d-flex justify-end mt-3" style="padding-top: 16px; border-top: 1px solid var(--border);">
            <button type="button" class="btn btn-outline" onclick="closeModal()">Đóng</button>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .status-badge { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; display: inline-block; }
        .status-badge.planned { background: var(--primary-soft); color: var(--primary); }
        .status-badge.inprogress { background: rgba(251,191,36,0.15); color: #D97706; }
        .status-badge.completed { background: rgba(52,211,153,0.15); color: #059669; }
        .btn-table { background:none; border:none; cursor:pointer; padding:6px 12px; border-radius:6px; font-size:0.85rem; font-weight:600; color:var(--primary); transition:all 0.2s; border: 1px solid var(--primary-soft); }
        .btn-table:hover { background:var(--primary-soft); }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', loadPlans);

        async function fetchJson(url, options = {}) {
            try {
                const response = await fetch(url, { headers: { 'Content-Type': 'application/json' }, ...options });
                return await response.json();
            } catch (e) { 
                return { success: false, message: 'Lỗi kết nối.' }; 
            }
        }

        async function loadPlans() {
            const result = await fetchJson('/Employee/Api/TeachingPlans');
            const tbody = document.getElementById('tableBody');
            
            if (result.success) {
                if (result.data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-5"><div class="empty-state"><i class="fa-solid fa-book-open"></i><p>Chưa có kế hoạch giảng dạy nào được giao.</p></div></td></tr>';
                    return;
                }
                
                tbody.innerHTML = result.data.map(p => {
                    let statusClass = p.status.toLowerCase();
                    let statusText = p.status;
                    if (statusText === 'Planned') statusText = 'Đã lên lịch';
                    else if (statusText === 'InProgress') statusText = 'Đang thực hiện';
                    else if (statusText === 'Completed') statusText = 'Hoàn thành';

                    return `
                        <tr>
                            <td><div class="badge badge-info"><i class="fa-solid fa-school"></i> ${p.className}</div></td>
                            <td>
                                <strong>${p.title}</strong>
                                <div class="text-muted mt-1" style="font-size: 0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">${p.description || '--'}</div>
                            </td>
                            <td>${p.startDate} <i class="fa-solid fa-arrow-right mx-1 text-muted"></i> ${p.endDate || '...'}</td>
                            <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                            <td style="text-align: right;">
                                <button class="btn-table" onclick='viewDetail(${JSON.stringify(p).replace(/'/g, "&#39;")})'>
                                    <i class="fa-solid fa-eye"></i> Xem nội dung
                                </button>
                            </td>
                        </tr>
                    `;
                }).join('');
                
                initPagination('teachingPlansTable', 10);
            } else {
                tbody.innerHTML = `<tr><td colspan="5" class="text-center text-danger">${result.message}</td></tr>`;
            }
        }

        function viewDetail(p) {
            document.getElementById('modalTitle').textContent = p.title;
            document.getElementById('modalDescription').textContent = p.description || 'Không có mô tả';
            document.getElementById('modalContent').textContent = p.content || 'Chưa có nội dung chi tiết';
            document.getElementById('modalOverlay').classList.add('active');
        }

        function closeModal() {
            document.getElementById('modalOverlay').classList.remove('active');
        }
    </script>
}

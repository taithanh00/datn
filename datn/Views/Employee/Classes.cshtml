@{
    ViewData["Title"] = "Lớp của tôi";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Lớp của tôi</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Danh sách các lớp bạn đang phụ trách</p>
    </div>
</div>

<div id="classesContainer" class="card-grid">
    <div style="grid-column: 1 / -1; text-align: center; padding: 40px;">
        <div class="spinner"></div>
        <p class="text-muted mt-2">Đang tải danh sách lớp học...</p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            loadMyClasses();
        });

        async function loadMyClasses() {
            try {
                const response = await fetch('/Employee/Api/MyClasses');
                const result = await response.json();
                
                const container = document.getElementById('classesContainer');
                
                if (result.success) {
                    if (result.data.length === 0) {
                        container.innerHTML = `
                            <div style="grid-column: 1 / -1;" class="card">
                                <div class="empty-state">
                                    <i class="fa-solid fa-info-circle"></i>
                                    <p>Bạn chưa được phân công phụ trách lớp học nào.</p>
                                </div>
                            </div>
                        `;
                        return;
                    }

                    container.innerHTML = result.data.map(item => `
                        <div class="card d-flex flex-column" style="height: 100%;">
                            <div class="d-flex justify-between align-center mb-3">
                                <div>
                                    <div class="badge badge-info mb-1">${item.role}</div>
                                    <h3 style="margin: 0; font-size: 1.25rem;">${item.className}</h3>
                                </div>
                                <div class="avatar" style="background: var(--primary-soft); color: var(--primary); width: 48px; height: 48px; font-size: 1.5rem;">
                                    <i class="fa-solid fa-school"></i>
                                </div>
                            </div>
                            
                            <div class="text-muted mb-3" style="font-size: 0.9rem;">
                                <i class="fa-solid fa-users me-1"></i> Sĩ số: <strong>${item.studentCount}</strong> học sinh
                            </div>
                            
                            <div style="margin-top: auto; display: grid; gap: 8px;">
                                <a href="/Employee/Attendance?classId=${item.classId}" class="btn btn-primary" style="width: 100%; justify-content: center;" data-transition>
                                    <i class="fa-solid fa-calendar-check"></i> Điểm danh ngay
                                </a>
                                <a href="/Employee/WorkSchedule?classId=${item.classId}" class="btn btn-outline" style="width: 100%; justify-content: center;" data-transition>
                                    <i class="fa-solid fa-list"></i> Xem danh sách
                                </a>
                            </div>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = `
                        <div style="grid-column: 1 / -1;" class="card">
                            <div class="page-alert error">
                                Lỗi: ${result.message}
                            </div>
                        </div>
                    `;
                }
            } catch (error) {
                console.error("Lỗi khi tải danh sách lớp:", error);
            }
        }
    </script>
}

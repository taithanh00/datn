@{
    ViewData["Title"] = "Hoạt động Ngoại khóa";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Hoạt động Ngoại khóa của Lớp</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Xem và đăng ký danh sách học sinh tham gia các sự kiện chung.</p>
    </div>
</div>

<div class="card">
    <div id="activityAlert" class="page-alert" style="display:none;"></div>
    <div class="table-container">
        <table id="activitiesTable">
            <thead>
                <tr>
                    <th>Hoạt động</th>
                    <th>Ngày tổ chức</th>
                    <th>Địa điểm</th>
                    <th style="text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="activitiesTableBody">
                <tr><td colspan="4" class="text-center text-muted" style="padding: 40px;"><div class="spinner"></div></td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Slide Panel for Participants -->
<div class="modal-overlay" id="modalOverlay"></div>
<div class="slide-panel" id="slidePanel">
    <div class="slide-panel-header">
        <h3 id="currentActivityName">HS tham gia</h3>
        <button class="close-btn" id="closePanelBtn" onclick="closePanel()">
            <i class="fa-solid fa-xmark" style="font-size: 1.2rem;"></i>
        </button>
    </div>
    <div class="slide-panel-body" style="display: flex; flex-direction: column;">
        <div id="participantAlert" class="page-alert" style="display:none;"></div>
        <p class="text-muted mb-3" style="font-size: 0.9rem;">Chọn các học sinh sẽ tham gia hoạt động này.</p>
        
        <div class="table-container" style="flex: 1; border: 1px solid var(--border); border-radius: var(--radius-md);">
            <table class="management-table" style="margin: 0;">
                <thead style="position: sticky; top: 0; z-index: 10;">
                    <tr>
                        <th style="width: 50px; text-align: center;">
                            <input type="checkbox" id="selectAll" />
                        </th>
                        <th>Học sinh</th>
                    </tr>
                </thead>
                <tbody id="participantsTableBody"></tbody>
            </table>
        </div>

        <div class="form-actions mt-3">
            <button type="button" class="btn btn-primary" id="saveParticipantsBtn" style="width: 100%; justify-content: center;">
                <i class="fa-solid fa-floppy-disk"></i> Lưu danh sách
            </button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/activities-employee.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/pages/activities-employee.js" asp-append-version="true"></script>
}

@{
    ViewData["Title"] = "Điểm danh";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var selectedClassId = ViewBag.SelectedClassId as int?;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Điểm danh Học sinh</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Ngày: <strong>@DateTime.Now.ToString("dd/MM/yyyy")</strong></p>
    </div>
    <div class="d-flex align-center gap-1">
        <label class="form-label" style="margin-bottom:0; white-space:nowrap;">Lớp:</label>
        <select class="form-select" id="classSelect" onchange="changeClass(this.value)" style="width:auto; min-width:200px;"></select>
    </div>
</div>

<div class="card">
    <div id="attendanceContent">
        <div class="empty-state"><i class="fa-solid fa-arrow-up"></i><p>Vui lòng chọn một lớp học để bắt đầu điểm danh</p></div>
    </div>
    <div id="footerActions" style="display:none; border-top:1px solid var(--border); padding-top:20px; margin-top:20px;" class="d-flex gap-1 justify-between">
        <button class="btn btn-outline" onclick="loadStudents(document.getElementById('classSelect').value)"><i class="fa-solid fa-rotate"></i> Làm mới</button>
        <button class="btn btn-primary" onclick="submitAttendance()"><i class="fa-solid fa-floppy-disk"></i> Lưu điểm danh</button>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/attendance.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.selectedClassId = '@(selectedClassId ?? 0)';
    </script>
    <script src="~/js/pages/attendance.js" asp-append-version="true"></script>
}

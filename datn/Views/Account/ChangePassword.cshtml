@model datn.Controllers.ProfileViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/profile.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <h1 class="page-title">🛡️ Bảo mật Tài khoản</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Cập nhật mật khẩu định kỳ để bảo vệ thông tin cá nhân của bạn</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 32px; margin-top: 32px; align-items: start;">
    
    <!-- Left Column: Security Tips -->
    <div class="card" style="background: linear-gradient(135deg, var(--primary-soft) 0%, transparent 100%); border-left: 4px solid var(--primary);">
        <h3 style="margin-bottom: 20px; font-size: 1.1rem; color: var(--primary);">Mẹo bảo mật</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
            <li style="display: flex; gap: 12px; align-items: flex-start;">
                <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.7rem;">1</div>
                <div style="font-size: 0.9rem; line-height: 1.4;">Sử dụng ít nhất 9 ký tự để đảm bảo độ phức tạp tối thiểu.</div>
            </li>
            <li style="display: flex; gap: 12px; align-items: flex-start;">
                <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.7rem;">2</div>
                <div style="font-size: 0.9rem; line-height: 1.4;">Kết hợp chữ hoa, chữ thường, số và ký tự đặc biệt (như !, @@, #).</div>
            </li>
            <li style="display: flex; gap: 12px; align-items: flex-start;">
                <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.7rem;">3</div>
                <div style="font-size: 0.9rem; line-height: 1.4;">Không nên sử dụng thông tin cá nhân như ngày sinh hay tên làm mật khẩu.</div>
            </li>
            <li style="display: flex; gap: 12px; align-items: flex-start;">
                <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.7rem;">4</div>
                <div style="font-size: 0.9rem; line-height: 1.4;">Tránh sử dụng cùng một mật khẩu cho nhiều dịch vụ khác nhau.</div>
            </li>
        </ul>

        <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); text-align: center;">
            <i class="fa-solid fa-spa" style="font-size: 3rem; color: var(--primary); opacity: 0.2;"></i>
            <div style="margin-top: 8px; font-weight: 700; color: var(--primary); opacity: 0.5;">SenHồng</div>
        </div>
    </div>

    <!-- Right Column: The Form -->
    <div class="card">
        @if (Context.Request.Query["reason"] == "must_change")
        {
            <div class="page-alert warning mb-4">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span><strong>Yêu cầu bắt buộc:</strong> Vui lòng đổi mật khẩu mới để tiếp tục sử dụng hệ thống.</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.PasswordError))
        {
            <div class="page-alert error mb-4">
                <i class="fa-solid fa-circle-xmark"></i>
                <span>@ViewBag.PasswordError</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.PasswordSuccess))
        {
            <div class="page-alert success mb-4">
                <i class="fa-solid fa-circle-check"></i>
                <span>@ViewBag.PasswordSuccess</span>
            </div>
        }

        <form method="post" action="/Account/ChangePassword" class="profile-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" for="oldpassword">Mật khẩu hiện tại</label>
                <input type="password" id="oldpassword" name="OldPassword" class="form-input" placeholder="Nhập mật khẩu hiện tại" required />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    <label class="form-label" for="newpassword">Mật khẩu mới</label>
                    <input type="password" id="newpassword" name="NewPassword" class="form-input" placeholder="Mật khẩu mới" required />
                    
                    <div style="margin-top: 12px; display: flex; flex-direction: column; gap: 8px;">
                        <div id="req-length" class="requirement"><i class="fa-solid fa-circle-dot"></i> Ít nhất 9 ký tự</div>
                        <div id="req-upper" class="requirement"><i class="fa-solid fa-circle-dot"></i> Ít nhất 1 chữ hoa</div>
                        <div id="req-special" class="requirement"><i class="fa-solid fa-circle-dot"></i> Ít nhất 1 ký tự đặc biệt</div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="confirmpassword">Xác nhận mật khẩu</label>
                    <input type="password" id="confirmpassword" name="ConfirmPassword" class="form-input" placeholder="Nhập lại mật khẩu mới" required />
                    <div id="req-match" class="requirement" style="margin-top: 12px;"><i class="fa-solid fa-circle-dot"></i> Mật khẩu khớp</div>
                </div>
            </div>

            <div style="display: flex; gap: 16px; margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border);">
                <button type="submit" id="btnSubmit" class="btn btn-primary" style="padding: 12px 24px; font-weight: 600;">
                    <i class="fa-solid fa-shield-check"></i> Lưu thay đổi mật khẩu
                </button>
                <a href="/" class="btn btn-outline" style="padding: 12px 24px; font-weight: 600;">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const newPass = document.getElementById('newpassword');
        const confirmPass = document.getElementById('confirmpassword');
        const btnSubmit = document.getElementById('btnSubmit');

        const reqLength = document.getElementById('req-length');
        const reqUpper = document.getElementById('req-upper');
        const reqSpecial = document.getElementById('req-special');
        const reqMatch = document.getElementById('req-match');

        function validatePassword() {
            const val = newPass.value;
            const confirmVal = confirmPass.value;

            const isLength = val.length >= 9;
            const isUpper = /[A-Z]/.test(val);
            const isSpecial = /[!@@#$%^&*()_+=\-\[\]{}|;:'",.<>?/\\ ]/.test(val);
            const isMatch = val === confirmVal && val !== '';

            updateUI(reqLength, isLength);
            updateUI(reqUpper, isUpper);
            updateUI(reqSpecial, isSpecial);
            updateUI(reqMatch, isMatch);

            if (isLength && isUpper && isSpecial && isMatch) {
                btnSubmit.disabled = false;
                btnSubmit.style.opacity = '1';
                btnSubmit.style.cursor = 'pointer';
            } else {
                btnSubmit.disabled = true;
                btnSubmit.style.opacity = '0.5';
                btnSubmit.style.cursor = 'not-allowed';
            }
        }

        function updateUI(el, isValid) {
            const icon = el.querySelector('i');
            if (isValid) {
                el.style.color = '#10b981';
                icon.className = 'fa-solid fa-circle-check';
                icon.style.color = '#10b981';
            } else {
                el.style.color = 'var(--text-muted)';
                icon.className = 'fa-solid fa-circle-dot';
                icon.style.color = 'var(--text-muted)';
                icon.style.opacity = '0.5';
            }
        }

        newPass.addEventListener('keyup', validatePassword);
        confirmPass.addEventListener('keyup', validatePassword);
        newPass.addEventListener('change', validatePassword);

        validatePassword();
    </script>
}

<style>
    .requirement {
        font-size: 0.85rem;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
    }
    
    .requirement i {
        font-size: 0.9rem;
    }

    .form-group .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
    }

    .form-input {
        width: 100%;
        padding: 10px 16px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--bg-main);
        color: var(--text-main);
        font-family: inherit;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px var(--primary-soft);
    }
</style>

@{
    ViewData["Title"] = "Kế hoạch Học phí";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Thiết lập Học phí</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Định nghĩa và khởi tạo mức học phí cho toàn trường</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
    <!-- Tuition Plans Section -->
    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 16px;">
            <h3 style="margin: 0; font-size: 1.1rem;">Mức thu theo lứa tuổi</h3>
            <button class="btn btn-primary" onclick="showCreatePlanModal()">
                <i class="fa-solid fa-plus"></i> Kế hoạch mới
            </button>
        </div>

        <div id="plansList" class="card-grid" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
            <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-muted);">
                <div class="spinner"></div><p class="mt-2">Đang tải danh sách...</p>
            </div>
        </div>
    </div>

    <!-- Monthly Generation Section -->
    <div class="card" style="border-top: 4px solid var(--success);">
        <h3 style="margin: 0 0 16px 0; font-size: 1.1rem;"><i class="fa-solid fa-bolt text-success me-2"></i> Khởi tạo tháng</h3>
        <p class="text-muted" style="font-size: 0.9rem; margin-bottom: 20px;">Tự động sinh hóa đơn học phí cho học sinh theo mức phí đã thiết lập.</p>
        
        <div class="form-group">
            <label class="form-label">Chọn Tháng</label>
            <select id="genMonth" class="form-select">
                @for (int i = 1; i <= 12; i++) {
                    var isSelected = DateTime.Now.Month == i;
                    <option value="@i" selected="@isSelected">Tháng @i</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Chọn Năm</label>
            <select id="genYear" class="form-select">
                <option value="2026" selected>2026</option>
                <option value="2027">2027</option>
            </select>
        </div>
        
        <button class="btn btn-primary" onclick="generateTuitions()" style="width: 100%; justify-content: center; background: var(--success); border-color: var(--success); height: 44px; margin-top: 8px;">
            <i class="fa-solid fa-play"></i> Bắt đầu khởi tạo
        </button>
    </div>
</div>

<!-- Modal Create Plan -->
<div class="modal-overlay" id="planModalOverlay">
    <div class="modal-card" style="width: 500px; max-width: 95vw;">
        <div class="modal-header">
            <div class="modal-title">Tạo kế hoạch học phí</div>
            <button class="modal-close" onclick="closePlanModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div>
            <form id="planForm">
                <div class="form-group">
                    <label class="form-label">Số tiền học phí (VNĐ) <span class="text-danger">*</span></label>
                    <input type="number" id="planAmount" class="form-input" placeholder="VD: 3500000" required>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <div class="form-group">
                        <label class="form-label">Từ tuổi <span class="text-danger">*</span></label>
                        <input type="number" id="planAgeFrom" class="form-input" placeholder="VD: 1" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Đến tuổi <span class="text-danger">*</span></label>
                        <input type="number" id="planAgeTo" class="form-input" placeholder="VD: 5" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Ghi chú (Tùy chọn)</label>
                    <textarea id="planNote" class="form-input" rows="2" placeholder="Thông tin thêm..."></textarea>
                </div>
            </form>
        </div>
        <div class="d-flex justify-end mt-4 gap-2">
            <button type="button" class="btn btn-outline" onclick="closePlanModal()">Hủy</button>
            <button type="button" class="btn btn-primary" onclick="savePlan()">Lưu kế hoạch</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/tuition-plans.js" asp-append-version="true"></script>
}

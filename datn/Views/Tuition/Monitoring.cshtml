@{
    ViewData["Title"] = "Theo dõi nộp học phí";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Theo dõi nộp học phí</h1>
        <p class="text-muted" style="font-size:0.85rem; margin-top:4px;">Kiểm tra và xác nhận tình trạng đóng phí của học sinh</p>
    </div>
</div>

<div class="card mb-4">
    <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        <div class="form-group" style="flex: 1; min-width: 150px; margin-bottom: 0;">
            <label class="form-label">Tháng</label>
            <select id="monMonth" class="form-select" onchange="loadMonitoring()">
                @for (int i = 1; i <= 12; i++) {
                    var isSelected = DateTime.Now.Month == i;
                    <option value="@i" selected="@isSelected">Tháng @i</option>
                }
            </select>
        </div>
        <div class="form-group" style="flex: 1; min-width: 150px; margin-bottom: 0;">
            <label class="form-label">Năm</label>
            <select id="monYear" class="form-select" onchange="loadMonitoring()">
                <option value="2026" selected>2026</option>
                <option value="2027">2027</option>
            </select>
        </div>
        <div class="form-group" style="flex: 1; min-width: 200px; margin-bottom: 0;">
            <label class="form-label">Trạng thái</label>
            <select id="monStatus" class="form-select" onchange="loadMonitoring()">
                <option value="">Tất cả trạng thái</option>
                <option value="true">Đã hoàn thành</option>
                <option value="false">Chưa thanh toán</option>
            </select>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-container">
        <table id="monitoringTableEl">
            <thead>
                <tr>
                    <th>Học sinh</th>
                    <th>Lớp học</th>
                    <th>Học phí + Phụ phí</th>
                    <th style="text-align: center;">Tình trạng</th>
                    <th style="text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="monitoringTable">
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <div class="spinner"></div><p class="mt-2">Đang tải dữ liệu...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/tuition-monitoring.js" asp-append-version="true"></script>
}

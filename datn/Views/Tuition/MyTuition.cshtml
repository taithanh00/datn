@model IEnumerable<datn.Models.Tuition>
@{
    ViewData["Title"] = "Học phí của con";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/tuition.css" asp-append-version="true" />
}

<div class="tuition-card">
    <div class="tuition-header">
        <div>
            <h2>Thông báo Học phí</h2>
            <p style="color: #6b7280; margin: 0;">Xem thông tin các khoản phí của con em mình</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align: center; padding: 40px; color: #9ca3af;">
            <i class="fa-solid fa-file-circle-check fa-3x" style="margin-bottom: 15px; opacity: 0.5;"></i>
            <p>Hiện chưa có thông báo học phí nào cho con bạn.</p>
        </div>
    }
    else
    {
        @foreach (var studentGroup in Model.GroupBy(t => t.Student))
        {
            <div style="margin-bottom: 30px;">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px; border-bottom: 2px solid #f3f4f6; padding-bottom: 10px;">
                    <img src="@(studentGroup.Key.AvatarPath ?? "/images/lion_orange.png")" style="width: 40px; height: 40px; border-radius: 50%;" />
                    <h3 style="margin: 0; color: #111827;">Học sinh: @studentGroup.Key.FirstName @studentGroup.Key.LastName</h3>
                </div>

                @foreach (var t in studentGroup)
                {
                    <div class="plan-item" style="border-left: 5px solid @(t.IsPaid ? "#22c55e" : "#ef4444");">
                        <div>
                            <div style="font-weight: 700; font-size: 15px;">Học phí tháng @t.Month/@t.Year</div>
                            <div style="font-size: 13px; color: #6b7280;">Hạn nộp: Ngày 15 tháng @t.Month</div>
                        </div>
                        <div style="text-align: right;">
                            <div class="plan-amount">@string.Format("{0:N0}", (t.TuitionPlan?.Amount ?? 0) + (t.ExtraFee ?? 0)) đ</div>
                            <div class="${t.isPaid ? 'status-paid' : 'status-unpaid'}" style="margin-top: 5px; display: inline-block;">
                                @if (t.IsPaid)
                                {
                                    <span class="status-paid"><i class="fa-solid fa-circle-check"></i> Đã thanh toán</span>
                                }
                                else
                                {
                                    <span class="status-unpaid"><i class="fa-solid fa-circle-exclamation"></i> Chưa thanh toán</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<div class="tuition-card" style="background: #eff6ff; border: 1px solid #dbeafe;">
    <h3 style="color: #1e40af; margin-top: 0;"><i class="fa-solid fa-circle-info"></i> Hướng dẫn nộp học phí</h3>
    <p style="color: #374151; font-size: 14px; line-height: 1.6;">
        Quý phụ huynh vui lòng hoàn thành việc nộp học phí trước ngày 15 hàng tháng qua các hình thức sau:<br/>
        1. <strong>Nộp trực tiếp:</strong> Tại văn phòng kế toán của trường.<br/>
        2. <strong>Chuyển khoản:</strong> Ngân hàng ABC - STK: 123456789 - Nội dung: [Mã học sinh] [Tháng nộp].
    </p>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - School Management System</title>
    <script type="importmap"></script>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    @* Reset css và khai báo font chữ sử dụng trong dự án  *@
    <link rel="stylesheet" href="~/css/base/reset.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/typography.css" asp-append-version="true" />
    
    @* Font Awesome cho Icon *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    @* Sử dụng font chữ Plus Jakarta Sans từ Google Fonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="~/css/modern-ui.css" asp-append-version="true" />
    
    @*Để cho từng page tự định nghĩa CSS*@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body> 
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fa-solid fa-graduation-cap mr-2"></i>
                <span>KinderCare</span>
            </div>
            
            <nav class="sidebar-nav">
                <a href="/" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="fa-solid fa-chart-line"></i> Tổng quan
                </a>

                @if (User.IsInRole("Manager"))
                {
                    <div class="nav-label">Quản trị hệ thống</div>
                    <a href="/Manager/Classes" class="nav-item">
                        <i class="fa-solid fa-school"></i> Quản lý Lớp học
                    </a>
                    <a href="/Manager/Students" class="nav-item">
                        <i class="fa-solid fa-user-graduate"></i> Quản lý Học sinh
                    </a>
                    <a href="/Manager/Employees" class="nav-item">
                        <i class="fa-solid fa-user-tie"></i> Quản lý Nhân sự
                    </a>

                    <div class="nav-label">Đào tạo & Tài chính</div>
                    <a href="/Manager/Schedules" class="nav-item">
                        <i class="fa-solid fa-calendar-days"></i> Thời khóa biểu
                    </a>
                    <a href="/Tuition" class="nav-item">
                        <i class="fa-solid fa-file-invoice-dollar"></i> Quản lý Học phí
                    </a>
                    <a href="/TeacherSalary" class="nav-item">
                        <i class="fa-solid fa-money-check-dollar"></i> Quản lý Tiền lương
                    </a>
                }

                @if (User.IsInRole("Employee"))
                {
                    <div class="nav-label">Giảng dạy</div>
                    <a href="/Employee/MyClasses" class="nav-item">
                        <i class="fa-solid fa- chalkboard-user"></i> Lớp của tôi
                    </a>
                    <a href="/Employee/Attendance" class="nav-item">
                        <i class="fa-solid fa-clipboard-user"></i> Điểm danh bé
                    </a>
                    
                    <div class="nav-label">Cá nhân</div>
                    <a href="/Employee/WorkAttendance" class="nav-item">
                        <i class="fa-solid fa-clock"></i> Chấm công
                    </a>
                    <a href="/Employee/LeaveRequest" class="nav-item">
                        <i class="fa-solid fa-calendar-minus"></i> Xin nghỉ phép
                    </a>
                }

                @if (User.IsInRole("Parent"))
                {
                    <div class="nav-label">Thông tin của bé</div>
                    <a href="/Parent/MyStudent" class="nav-item">
                        <i class="fa-solid fa-child"></i> Kết quả học tập
                    </a>
                    <a href="/Parent/Tuition" class="nav-item">
                        <i class="fa-solid fa-wallet"></i> Học phí của bé
                    </a>
                }

                <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid var(--border);">
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-item" style="width: 100%; background: none; border: none; cursor: pointer;">
                            <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="main-wrapper">
            <header class="header">
                <div class="header-left">
                    <div class="breadcrumb">Dashboards / <span>@ViewData["Title"]</span></div>
                </div>
                <div class="header-right">
                    <div class="user-profile" style="display: flex; align-items: center; gap: 12px;">
                        <div class="user-info" style="text-align: right;">
                            <div style="font-size: 0.85rem; font-weight: 600;">@User.Identity?.Name</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">
                                @(User.IsInRole("Manager") ? "Quản lý" : User.IsInRole("Employee") ? "Giáo viên" : "Phụ huynh")
                            </div>
                        </div>
                        <img src="https://ui-avatars.com/api/?name=@User.Identity?.Name&background=007AFF&color=fff" 
                             alt="Avatar" style="width: 36px; height: 36px; border-radius: 50%;">
                    </div>
                </div>
            </header>

            <main class="content-body">
                @RenderBody()
            </main>
        </div>
    </div>

    @* Để cho từng page tự định nghĩa JS *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SenHồng</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/modern-ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dark-mode.css" asp-append-version="true" />

    <script>
        (function(){
            var t = localStorage.getItem('senhong-theme');
            if (t) document.documentElement.setAttribute('data-theme', t);
            else if (window.matchMedia('(prefers-color-scheme: dark)').matches) document.documentElement.setAttribute('data-theme', 'dark');
        })();
    </script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app-container">
        <aside class="sidebar" id="sidebar">
            <a href="/" class="sidebar-header" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 12px;">
                <i class="fa-solid fa-spa" style="font-size:1.4rem; color: #e91e63;"></i>
                <span>SenHồng</span>
            </a>

            <nav class="sidebar-nav">
                <a href="/" class="nav-item" data-transition>
                    <i class="fa-solid fa-chart-line"></i> Tổng quan
                </a>

                @if (ViewBag.Role == "Manager")
                {
                    <div class="nav-label">Quản trị hệ thống</div>
                    <a href="/Manager/Classes" class="nav-item" data-transition><i class="fa-solid fa-school"></i> Quản lý lớp học</a>
                    <a href="/Manager/Subjects" class="nav-item" data-transition><i class="fa-solid fa-book"></i> Danh mục môn học</a>
                    <a href="/Manager/Schedules" class="nav-item" data-transition><i class="fa-solid fa-calendar-days"></i> Thời khóa biểu</a>
                    <a href="/Manager/Students" class="nav-item" data-transition><i class="fa-solid fa-user-graduate"></i> Học sinh</a>
                    <a href="/Manager/Parents" class="nav-item" data-transition><i class="fa-solid fa-users-viewfinder"></i> Phụ huynh</a>
                    <a href="/Manager/Teachers" class="nav-item" data-transition><i class="fa-solid fa-user-tie"></i> Nhân sự</a>
                    <a href="/HolidayManagement" class="nav-item" data-transition><i class="fa-solid fa-umbrella-beach"></i> Ngày lễ</a>
                    <a href="/Manager/Activities" class="nav-item" data-transition><i class="fa-solid fa-calendar-check"></i> Hoạt động</a>

                    <div class="nav-label">Đào tạo</div>
                    <a href="/Manager/Assignments" class="nav-item" data-transition><i class="fa-solid fa-calendar-days"></i> Phân công giảng dạy</a>
                    <a href="/Manager/TeachingPlans" class="nav-item" data-transition><i class="fa-solid fa-list-check"></i> Kế hoạch giảng dạy</a>
                    <a href="/Manager/Curriculums" class="nav-item" data-transition><i class="fa-solid fa-book-open"></i> Chương trình học</a>

                    <div class="nav-label">Tài chính</div>
                    <a href="/Tuition" class="nav-item" data-transition><i class="fa-solid fa-file-invoice-dollar"></i> Học phí</a>
                    <a href="/TeacherSalary" class="nav-item" data-transition><i class="fa-solid fa-money-check-dollar"></i> Tiền lương</a>

                    <div class="nav-label">Phê duyệt</div>
                    <a href="/LeaveApproval" class="nav-item" data-transition><i class="fa-solid fa-clipboard-check"></i> Duyệt nghỉ phép</a>
                }

                @if (ViewBag.Role == "Employee")
                {
                    <div class="nav-label">Giảng dạy</div>
                    <a href="/Employee/Classes" class="nav-item" data-transition><i class="fa-solid fa-chalkboard-user"></i> Lớp của tôi</a>
                    <a href="/Employee/Attendance" class="nav-item" data-transition><i class="fa-solid fa-clipboard-user"></i> Điểm danh</a>
                    <a href="/Employee/StudyReport" class="nav-item" data-transition><i class="fa-solid fa-file-signature"></i> Nhận xét & Báo cáo</a>
                    <a href="/Employee/TeachingPlan" class="nav-item" data-transition><i class="fa-solid fa-book-open-reader"></i> Kế hoạch giảng dạy</a>
                    <a href="/Employee/Activities" class="nav-item" data-transition><i class="fa-solid fa-calendar-check"></i> Hoạt động</a>

                    <div class="nav-label">Cá nhân</div>
                    <a href="/TimeAttendance" class="nav-item" data-transition><i class="fa-solid fa-clock"></i> Chấm công</a>
                    <a href="/LeaveRequest" class="nav-item" data-transition><i class="fa-solid fa-calendar-minus"></i> Nghỉ phép</a>
                    <a href="/Employee/WorkSchedule" class="nav-item" data-transition><i class="fa-solid fa-calendar-days"></i> Lịch dạy cá nhân</a>
                    <a href="/TeacherSalary/MySalary" class="nav-item" data-transition><i class="fa-solid fa-wallet"></i> Phiếu lương</a>
                }

                @if (ViewBag.Role == "Parent")
                {
                    <div class="nav-label">Con của tôi</div>
                    <a href="/Parent/Children" class="nav-item" data-transition><i class="fa-solid fa-child"></i> Thông tin bé</a>
                    <a href="/Parent/AttendanceReport" class="nav-item" data-transition><i class="fa-solid fa-calendar-check"></i> Chuyên cần</a>
                    <a href="/Parent/StudyReports" class="nav-item" data-transition><i class="fa-solid fa-chart-bar"></i> Học tập</a>
                    <a href="/Parent/TeachingPlan" class="nav-item" data-transition><i class="fa-solid fa-book"></i> Kế hoạch lớp</a>
                    <a href="/Parent/Activities" class="nav-item" data-transition><i class="fa-solid fa-calendar-heart"></i> Hoạt động của bé</a>
                    <a href="/Tuition/MyTuition" class="nav-item" data-transition><i class="fa-solid fa-wallet"></i> Học phí</a>
                }

                <div style="margin-top:auto; padding-top:20px; border-top:1px solid var(--border);">
                    <a href="/Account/Profile" class="nav-item" data-transition><i class="fa-solid fa-user-gear"></i> Tài khoản</a>
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-item" style="width:100%; background:none; border:none; cursor:pointer; text-align:left; font-family:inherit; font-size:inherit; color:inherit;">
                            <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </nav>
        </aside>

        <div class="main-wrapper">
            <header class="header">
                <div class="header-left d-flex align-center gap-2">
                    <button class="hamburger" id="hamburgerBtn"><i class="fa-solid fa-bars"></i></button>
                    <div class="breadcrumb">
                        <span style="color:var(--text-muted)">@ViewContext.RouteData.Values["Controller"]</span> /
                        <span>@ViewData["Title"]</span>
                    </div>
                </div>
                <div class="header-right d-flex align-center gap-2">
                    <!-- Notifications -->
                    <div style="position:relative;">
                        <button class="theme-toggle" id="notificationToggle" style="position:relative;">
                            <i class="fa-solid fa-bell"></i>
                            <span id="notificationCount" style="display:none; position:absolute; top:0; right:0; background:var(--danger); color:#fff; font-size:0.6rem; width:16px; height:16px; border-radius:50%; align-items:center; justify-content:center; font-weight:700;"></span>
                        </button>
                        <div id="notificationMenu" class="notification-dropdown">
                            <div style="padding:16px; font-weight:700; border-bottom:1px solid var(--border);">Thông báo</div>
                            <div id="notificationList" style="max-height:320px; overflow-y:auto; padding:8px;">
                                <div class="empty-state" style="padding:32px 16px;"><i class="fa-solid fa-bell-slash"></i><p>Không có thông báo</p></div>
                            </div>
                        </div>
                    </div>
                    <!-- Dark Mode -->
                    <button class="theme-toggle" id="themeToggle" data-tooltip="Giao diện">
                        <i class="fa-solid fa-moon"></i><i class="fa-solid fa-sun"></i>
                    </button>
                    <!-- User -->
                    <div class="d-flex align-center gap-1">
                        <div style="text-align:right;">
                            <div style="font-size:0.85rem; font-weight:600;">@ViewBag.FullName</div>
                            <div style="font-size:0.72rem; color:var(--text-muted);">
                                @(ViewBag.Role == "Manager" ? "Quản lý" : ViewBag.Role == "Employee" ? "Giáo viên" : "Phụ huynh")
                            </div>
                        </div>
                        <img src="@ViewBag.UserAvatar"
                             alt="Avatar" style="width:36px; height:36px; border-radius:50%; border:2px solid white;" onerror="this.src='/images/lion_blue.png'">
                    </div>
                </div>
            </header>

            <main class="content-body page-wrapper">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" style="position:fixed; right:20px; top:80px; z-index:9999; display:flex; flex-direction:column; gap:8px;"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

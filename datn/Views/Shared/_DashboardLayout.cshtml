<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dashboard</title>

    <!-- Base CSS -->
    <link rel="stylesheet" href="~/css/base/reset.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/typography.css" asp-append-version="true" />

    <!-- Dashboard CSS -->
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Icons (Font Awesome) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Page-specific styles -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- SIDEBAR / LEFT PANEL -->
        @await Html.PartialAsync("_SideMenu", (object)ViewBag.Role)

        <!-- MAIN CONTENT AREA -->
        <div class="dashboard-main">
            <!-- TOP BAR / HEADER -->
            @await Html.PartialAsync("_TopBar")

            <!-- CONTENT -->
            <div class="dashboard-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/pages/dashboard.js" asp-append-version="true"></script>

    <!-- Page-specific scripts -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

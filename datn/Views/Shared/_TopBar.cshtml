@{
    var username = ViewBag.Username as string ?? "User";
    var role = ViewBag.Role as string ?? "";
    var userAvatar = ViewBag.UserAvatar as string ?? "/images/lion_blue.png";
    var initial = username.Length > 0 ? username[0].ToString().ToUpper() : "U";
}

<!-- TOP BAR / HEADER -->
<header class="dashboard-topbar">
    <!-- Left: Page Title + Breadcrumb -->
    <div class="topbar-left">
        <div class="page-title">
            <h1>@ViewData["Title"]</h1>
        </div>
    </div>

    <!-- Center: Search Bar -->
    <div class="topbar-center">
        <div class="search-box">
            <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" 
                   class="search-input" 
                   placeholder="Tìm kiếm..." 
                   id="globalSearch" />
        </div>
    </div>

    <!-- Right: Notifications + Profile Dropdown -->
    <div class="topbar-right">
        <!-- Notification Bell -->
        <div class="notification-wrapper" id="notificationWrapper">
            <button class="topbar-icon-btn notification-btn" type="button" id="notificationToggle" title="Thông báo">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                </svg>
                <span class="notification-badge" id="notificationCount" style="display: none;">0</span>
            </button>

            <!-- Notification Dropdown Menu -->
            <div class="notification-menu" id="notificationMenu">
                <div class="notification-header">
                    <h3>Thông báo</h3>
                    <button id="markAllRead" class="btn-text">Đánh dấu tất cả đã đọc</button>
                </div>
                <div class="notification-list" id="notificationList">
                    <!-- Notifications will be loaded here via JS -->
                    <div class="notification-empty">Đang tải thông báo...</div>
                </div>
                <div class="notification-footer">
                    <a href="/Account/Notifications">Xem tất cả thông báo</a>
                </div>
            </div>
        </div>

        <!-- Profile Dropdown -->
        <div class="profile-dropdown" id="profileDropdown">
            <!-- Profile Button (Avatar) -->
            <button class="profile-btn" type="button" id="profileToggle">
                <div class="profile-avatar">
                    <img src="@userAvatar" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                </div>
                <span class="profile-name">@username</span>
                <svg class="dropdown-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" 
                          d="M5.293 7.293a1 1 0 011.414 0L10 10.586la3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" 
                          clip-rule="evenodd"/>
                </svg>
            </button>

            <!-- Dropdown Menu -->
            <div class="profile-menu" id="profileMenu">
                <!-- User Info -->
                <div class="profile-menu-header">
                    <div class="menu-user-avatar">
                        <img src="@userAvatar" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                    </div>
                    <div>
                        <div class="menu-user-name">@username</div>
                        <div class="menu-user-role">
                            @if (role == "Manager")
                            {
                                <span>Quản lý</span>
                            }
                            else if (role == "Employee")
                            {
                                <span>Giáo viên</span>
                            }
                            else if (role == "Parent")
                            {
                                <span>Phụ huynh</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="profile-menu-divider"></div>

                <!-- Menu Items -->
                <a href="/Account/Profile" class="profile-menu-item">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0M12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <span>Thông tin cá nhân</span>
                </a>

                <a href="/Account/Settings" class="profile-menu-item">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span>Cài đặt</span>
                </a>

                <a href="/Account/ChangePassword" class="profile-menu-item">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                    <span>Đổi mật khẩu</span>
                </a>

                <div class="profile-menu-divider"></div>

                <!-- Logout Button -->
                <form method="post" action="/Auth/Logout" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="profile-menu-item logout-item">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        <span>Đăng xuất</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</header>

@section Scripts {
    <script src="~/js/components/topbar.js" asp-append-version="true"></script>
}